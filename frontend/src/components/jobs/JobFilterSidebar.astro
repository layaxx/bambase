---
import JobFilterItem from "./JobFilterItem.astro"
import IconSliders from "@/components/icons/IconSliders.astro"
import { useTranslations } from "@/i18n/translations"

type FilterItem = { label: string; checked: boolean; url: string }

interface Props {
  typeItems: FilterItem[]
  fieldItems: FilterItem[]
  workModeItems: FilterItem[]
  hasActiveFilter: boolean
  clearUrl: string
}

const { typeItems, fieldItems, workModeItems } = Astro.props
const t = useTranslations(Astro.locals.locale)
---

<aside class="hidden lg:sticky lg:top-4 lg:flex lg:flex-col">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <IconSliders class="h-4 w-4 text-base-content/40" />
      <span class="font-medium">{t.jobs.filterHeading}</span>
    </div>
  </div>

  <div class="mb-5">
    <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
      {t.jobs.filterType}
    </h3>
    {typeItems.map((item) => <JobFilterItem {...item} />)}
  </div>

  <div class="mb-5">
    <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
      {t.jobs.filterField}
    </h3>
    {fieldItems.map((item) => <JobFilterItem {...item} />)}
  </div>

  <div class="mb-5">
    <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
      {t.jobs.fieldWorkMode}
    </h3>
    {workModeItems.map((item) => <JobFilterItem {...item} />)}
  </div>
</aside>
