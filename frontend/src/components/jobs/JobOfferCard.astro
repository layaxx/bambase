---
import type { JobOffer } from "@/utils/api/job-offers"
import { useTranslations } from "@/i18n/translations"
import IconStore from "../icons/IconStore.astro"
import { formatJobLocation, formatJobOfferDate } from "@/utils/job-formatting"
import JobTypeBadge from "./JobTypeBadge.astro"

interface Props {
  job: JobOffer
}

const { job } = Astro.props
const t = useTranslations(Astro.locals.locale)
---

<a
  class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md no-underline h-full"
  href={`/job/${job.uuid}`}
>
  <div class="mb-2 flex flex-row items-center justify-between">
    <JobTypeBadge isSmall jobType={job.job_type} />
    <span class="shrink-0 text-xs text-base-content/70"
      >{formatJobOfferDate(job.createdAt, Astro.locals.locale)}</span
    >
  </div>
  <h3 class="mb-1 font-semibold leading-tight text-base-content group-hover:text-primary">
    {job.title}
  </h3>
  <div class="mb-2 flex flex-row items-center text-sm text-base-content/70">
    <div class="flex items-center gap-1.5">
      <IconStore class="h-3.5 w-3.5 shrink-0" />
      <span class="truncate"
        >{job.company}, {
          formatJobLocation(job, {
            remote: t.jobs.workModes.remote,
            hybrid: t.jobs.workModes.hybrid,
          })
        }</span
      >
    </div>
  </div>
  <p class="mb-3 line-clamp-2 text-sm text-base-content/70">{job.description}</p>
  <div class="mt-auto flex items-center justify-between gap-2 text-xs text-base-content/70">
    <span class="badge badge-ghost badge-sm">{t.jobs.jobFields[job.field]}</span>
    <span class="shrink-0">{t.jobs.workingHours(job.working_hours)}</span>
  </div>
</a>
