---
import IconCheck from "@/components/icons/IconCheck.astro"

interface Props {
  label: string
  count: number
  checked: boolean
  url: string
}

const { label, count, checked, url } = Astro.props
---

<a
  class:list={[
    "flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors",
    { "bg-neutral text-neutral-content": checked, "hover:bg-base-200": !checked },
  ]}
  href={url}
>
  <div class="flex items-center gap-2">
    <span
      class:list={[
        "flex h-4 w-4 shrink-0 items-center justify-center rounded border",
        {
          "border-neutral-content/60 bg-neutral-content/20": checked,
          "border-base-content/40": !checked,
        },
      ]}
    >
      {checked && <IconCheck class="h-2.5 w-2.5" />}
    </span>
    <span>{label}</span>
  </div>
  <span class="text-xs text-base-content/40">{count}</span>
</a>
