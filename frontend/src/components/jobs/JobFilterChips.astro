---
import IconX from "@/components/icons/IconX.astro"
import { useTranslations } from "@/i18n/translations"

type FilterItem = { label: string; checked: boolean; url: string }

interface Props {
  typeItems: FilterItem[]
  fieldItems: FilterItem[]
  workModeItems: FilterItem[]
  hasActiveFilter: boolean
  clearUrl: string
}

const { typeItems, fieldItems, workModeItems, hasActiveFilter, clearUrl } = Astro.props
const t = useTranslations(Astro.locals.locale)
const activeItems = [...typeItems, ...fieldItems, ...workModeItems].filter((i) => i.checked)
---

{
  hasActiveFilter && (
    <div class="mb-4 flex flex-wrap items-center gap-2">
      {activeItems.map((i) => (
        <a class="badge badge-neutral gap-1 pr-1" href={i.url}>
          {i.label}
          <IconX class="h-3 w-3" />
        </a>
      ))}
      <a class="text-sm text-primary hover:underline" href={clearUrl}>
        {t.jobs.clearFilters}
      </a>
    </div>
  )
}
