---
import Sidebar from "./Sidebar.astro"
import StudentGroup from "./StudentGroup.astro"
import { fetchStudentGroups } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconUsers from "./icons/IconUsers.astro"

const t = useTranslations(Astro.locals.locale)
const groups = await fetchStudentGroups()

const LIMIT = 5
---

<section id="groups">
  <!-- Section header -->
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-secondary/20">
        <IconUsers class="h-5 w-5 text-secondary" />
      </div>
      <div>
        <h2 class="text-xl font-semibold">{t.groups.title}</h2>
        <p class="text-sm text-base-content/70">{t.groups.subtitle}</p>
      </div>
    </div>
  </div>

  <!-- Original grid: article (col-span-2) + sidebar (col-start-3, row-span-2) + groups (auto-placed) -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="main-grid">
    <article class="md:col-span-2">
      <p class="text-sm text-base-content/70 mb-4">
        {t.groups.description}
      </p>
      <div>
        <select class="select select-bordered select-sm w-auto" id="sort-select">
          <option value="random">{t.groups.sortRandom}</option>
          <option value="name">{t.groups.sortByName}</option>
        </select>
      </div>
    </article>

    <Sidebar />

    {
      groups.map((group, i) => (
        <div data-group data-group-name={group.name} hidden={i >= LIMIT}>
          <StudentGroup group={group} />
        </div>
      ))
    }
  </div>

  <div class="mt-4">
    <button class="btn btn-soft btn-sm" id="show-all-btn">{t.groups.showAll}</button>
  </div>
</section>

<script
  define:vars={{ LIMIT, showAllText: t.groups.showAll, showLessText: t.groups.showLess }}
  is:inline
>
  const grid = document.getElementById("main-grid")
  const sortSelect = document.getElementById("sort-select")
  const showAllBtn = document.getElementById("show-all-btn")
  let showAll = false

  function getGroups() {
    return [...grid.querySelectorAll("[data-group]")]
  }

  function updateVisibility() {
    getGroups().forEach((el, i) => {
      el.hidden = !showAll && i >= LIMIT
    })
  }

  function sortGroups(order) {
    const groupEls = getGroups()
    if (order === "name") {
      groupEls.sort((a, b) => a.dataset.groupName.localeCompare(b.dataset.groupName))
    } else {
      groupEls.sort(() => Math.random() - 0.5)
    }
    groupEls.forEach((el) => grid.appendChild(el))
    updateVisibility()
  }

  sortSelect.addEventListener("change", (e) => sortGroups(e.target.value))

  showAllBtn.addEventListener("click", () => {
    showAll = !showAll
    showAllBtn.textContent = showAll ? showLessText : showAllText
    updateVisibility()
  })

  sortGroups("random")
</script>
