---
import { useTranslations } from "@/i18n/translations"
import IconCalendar from "./icons/IconCalendar.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"
import { fetchOngoingOrUpcomingEvents } from "@/utils/api/events"
import EventCard from "./EventCard.astro"
import ApiDownBanner from "./ApiDownBanner.astro"

const t = useTranslations(Astro.locals.locale)

const { data: upcomingOrOngoingEvents, apiDown } = await fetchOngoingOrUpcomingEvents(4)
---

<section class="mb-12" id="events">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg badge-soft badge-primary"
      >
        <IconCalendar class="h-5 w-5" />
      </div>
      <div>
        <a class="text-xl font-semibold hover:text-primary no-underline" href="/events"
          >{t.events.title}</a
        >
        <p class="text-sm text-base-content/70">
          {t.events.countToday(upcomingOrOngoingEvents.length)}
        </p>
      </div>
    </div>
    <a class="btn btn-ghost btn-sm flex gap-1" href="/events">
      {t.events.showAll}
      <IconArrowRight class="h-4 w-4" />
    </a>
  </div>
  {
    apiDown ? (
      <ApiDownBanner />
    ) : upcomingOrOngoingEvents.length === 0 ? (
      <p class="text-base-content/70 rounded-xl border border-base-300 bg-base-100 p-6">
        {t.events.none}
      </p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {upcomingOrOngoingEvents.map((event) => (
          <EventCard event={event} short />
        ))}
      </div>
    )
  }
</section>
