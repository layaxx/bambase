---
interface Props {
  title: string;
  color: string;
  href?: string;
  backgroundImage?: string;
}

const { title, color, href, backgroundImage } = Astro.props;

const colorMap: Record<string, string> = {
  blue: "text-blue-600",
  pink: "text-pink-600",
  green: "text-green-600",
  gray: "text-gray-500",
};
const colorClass = colorMap[color] ?? colorMap.gray;

const firstWord = title.split(" ")[0].toUpperCase();
const rest = title.split(" ").slice(1).join(" ");
---

<div
  class="card border border-base-300 overflow-hidden"
  style={backgroundImage
    ? `background-image: url(${backgroundImage}); background-size: cover; background-position: center;`
    : undefined}
>
  <div class="p-4 pb-2">
    <h2
      class:list={[
        "card-title text-xl",
        backgroundImage && "inline-block bg-white/80 px-2 rounded-md",
      ]}
    >
      {
        href ? (
          <a href={href} class="hover:underline text-inherit">
            <span class={colorClass}>{firstWord}</span> {rest}
          </a>
        ) : (
          <>
            <span class={colorClass}>{firstWord}</span> {rest}
          </>
        )
      }
    </h2>
  </div>
  <slot />
</div>
