---
import { actions } from "astro:actions"
import { useTranslations } from "@/i18n/translations"
import IconFlag from "@/components/icons/IconFlag.astro"

interface Props {
  targetType: "event" | "job"
  targetId: string
}

const { targetType, targetId } = Astro.props
const t = useTranslations(Astro.locals.locale)
---

<button
  class="btn btn-ghost btn-sm gap-1.5 text-base-content/40"
  onclick="document.getElementById('reportModal').showModal()"
  type="button"
>
  <IconFlag class="h-4 w-4" />
  {targetType === "job" ? t.reports.reportJob : t.reports.reportEvent}
</button>

<dialog class="modal" id="reportModal">
  <div class="modal-box">
    <h3 class="mb-4 text-lg font-bold">{t.reports.modalTitle}</h3>
    <form action={actions.reports.submit} method="POST">
      <input name="target_type" type="hidden" value={targetType} />
      <input name="target_id" type="hidden" value={targetId} />

      <div class="form-control">
        <label class="label" for="report-reason">
          <span class="label-text">{t.reports.reasonLabel}</span>
        </label>
        <select class="select select-bordered w-full" id="report-reason" name="reason" required>
          <option value="">{t.reports.reasonPlaceholder}</option>
          <option value="spam">{t.reports.reasonSpam}</option>
          <option value="inappropriate">{t.reports.reasonInappropriate}</option>
          <option value="outdated">{t.reports.reasonOutdated}</option>
          <option value="other">{t.reports.reasonOther}</option>
        </select>
      </div>

      <div class="form-control mt-3">
        <label class="label" for="report-details">
          <span class="label-text">{t.reports.detailsLabel}</span>
        </label>
        <textarea
          class="textarea textarea-bordered w-full"
          id="report-details"
          name="details"
          placeholder={t.reports.detailsPlaceholder}
          rows="3"></textarea>
      </div>

      <div class="modal-action">
        <button class="btn" onclick="document.getElementById('reportModal').close()" type="button">
          {t.reports.cancel}
        </button>
        <button class="btn btn-warning" type="submit">
          {t.reports.submit}
        </button>
      </div>
    </form>
  </div>
  <form class="modal-backdrop" method="dialog">
    <button>close</button>
  </form>
</dialog>
