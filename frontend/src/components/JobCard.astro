---
import { fetchJobOffers } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconBriefcase from "./icons/IconBriefcase.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"
import JobOfferCard from "./jobs/JobOfferCard.astro"

const t = useTranslations(Astro.locals.locale)

const jobs = await fetchJobOffers(3)
---

<section class="mb-12" id="jobs">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-success/20">
        <IconBriefcase class="h-5 w-5 text-success" />
      </div>
      <div>
        <a class="text-xl font-semibold hover:text-primary no-underline" href="/jobs"
          >{t.jobs.title}</a
        >
        <p class="text-sm text-base-content/70">{t.jobs.subtitle}</p>
      </div>
    </div>
    <a class="btn btn-ghost btn-sm flex gap-1" href="/jobs">
      {t.jobs.showAll}
      <IconArrowRight class="h-4 w-4" />
    </a>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      jobs.length === 0 && (
        <p class="text-base-content/70 rounded-xl border border-base-300 bg-base-100 p-6">
          {t.jobs.noJobs}
        </p>
      )
    }
    {jobs.map((job) => <JobOfferCard job={job} />)}
  </div>
</section>
