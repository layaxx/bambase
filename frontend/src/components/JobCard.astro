---
import { fetchJobOffers } from "../utils/api"
import { useTranslations } from "../i18n/translations"

const t = useTranslations(Astro.locals.locale)

const jobs = await fetchJobOffers(3)
---

<section id="jobs" class="mb-12">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-100">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5 text-green-700"
          aria-hidden="true"
        >
          <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
          <rect width="20" height="14" x="2" y="6" rx="2"></rect>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-semibold">{t.jobs.title}</h2>
        <p class="text-sm text-base-content/60">{t.jobs.subtitle}</p>
      </div>
    </div>
    <a href="/jobs" class="btn btn-ghost btn-sm hidden sm:flex gap-1">
      {t.jobs.showAll}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4"
        aria-hidden="true"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      jobs.length === 0 && (
        <p class="text-base-content/60 rounded-xl border border-base-300 bg-base-100 p-6">
          {t.jobs.noJobs}
        </p>
      )
    }
    {
      jobs.map((job) => (
        <a
          href={`/job/${job.documentId}`}
          class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md no-underline">
          <h3 class="mb-1 font-semibold leading-tight text-base-content group-hover:text-primary">
            {job.title}
          </h3>
          <div class="mb-2 flex items-center gap-1.5 text-sm text-base-content/60">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-3.5 w-3.5 shrink-0"
              aria-hidden="true">
              <path d="M10 12h4" />
              <path d="M10 8h4" />
              <path d="M14 21v-3a2 2 0 0 0-4 0v3" />
              <path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2" />
              <path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16" />
            </svg>
            <span class="truncate">{job.company}</span>
          </div>
          <p class="mb-3 line-clamp-2 text-sm text-base-content/60">{job.description}</p>
          <div class="mt-auto flex items-center gap-1.5 text-sm text-base-content/60">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-3.5 w-3.5 shrink-0"
              aria-hidden="true">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="truncate">{job.location}</span>
          </div>
        </a>
      ))
    }
  </div>
</section>
