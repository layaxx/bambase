---
import { fetchMensaMeals } from "@/utils/api"
import { getRelevantDay } from "@/utils/mensa"
import dayjs from "dayjs"
import { useTranslations } from "@/i18n/translations"
import IconUtensils from "./icons/IconUtensils.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"
import MealBadge from "./mensa/MealBadge.astro"

const t = useTranslations(Astro.locals.locale)

const now = dayjs()
const relevantDay = getRelevantDay(now)
const isToday = relevantDay.isSame(now, "day")
const relevantDayId = relevantDay.format("YYYY-MM-DD")
const relevantDayFormatted = relevantDay.toDate().toLocaleDateString(t.mensa.dateLocale, {
  day: "numeric",
  month: "long",
})

const locations = [
  { id: "feki", label: "Feki", strapiName: "Feki" },
  { id: "austrasse", label: "Austraße", strapiName: "Austraße" },
  { id: "erba", label: "Erba", strapiName: "Erba" },
] as const

const meals = await fetchMensaMeals(relevantDay)

const mealsByLocation = Object.fromEntries(
  locations.map((loc) => [loc.id, meals.filter((m) => m.location === loc.strapiName)])
)
---

<section class="mb-12" id="mensa">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-warning/20">
        <IconUtensils class="h-5 w-5 text-warning" />
      </div>
      <div>
        <a class="text-xl font-semibold hover:text-primary no-underline" href="/mensa"
          >{t.mensa.cardTitle}</a
        >
        <p class="text-sm text-base-content/70">
          {
            isToday
              ? t.mensa.cardSubtitleToday(relevantDayFormatted)
              : t.mensa.cardSubtitle(relevantDayFormatted)
          }
        </p>
      </div>
    </div>
    <a class="btn btn-ghost btn-sm flex gap-1" href="/mensa">
      {t.mensa.fullPlan}
      <IconArrowRight class="h-4 w-4" />
    </a>
  </div>

  <div class="rounded-xl border border-base-300 bg-base-100 p-4 sm:p-6">
    <div class="mb-4 flex gap-1 rounded-lg bg-base-200 p-1">
      {
        locations.map((loc, i) => (
          <button
            class:list={[
              "flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-all",
              {
                "bg-base-100 text-base-content shadow-sm": i === 0,
                "text-base-content/70 hover:text-base-content": i !== 0,
              },
            ]}
            data-loc={loc.id}
            data-mensa-btn
            type="button"
          >
            {loc.label}
          </button>
        ))
      }
    </div>

    {
      locations.map((loc, i) => (
        <ul class="flex flex-col gap-2" hidden={i !== 0} id={`meals-${loc.id}`}>
          {mealsByLocation[loc.id].length === 0 ? (
            <li class="text-base-content/70 text-sm">{t.mensa.noData}</li>
          ) : (
            mealsByLocation[loc.id].map((meal) => (
              <li>
                <a
                  class="flex items-center justify-between gap-3 rounded-lg border border-base-300 p-3 transition-colors hover:bg-base-200 no-underline"
                  href={`/mensa#${relevantDayId}-${loc.id}-${meal.id}`}
                >
                  <div class="flex min-w-0 flex-wrap items-center gap-1.5">
                    <span class="text-sm text-base-content">{meal.name}</span>
                    {meal.isVegan && <MealBadge type="vegan" />}
                    {!meal.isVegan && meal.isVegetarian && <MealBadge type="vegetarian" />}
                  </div>
                  <span class="shrink-0 font-semibold text-sm text-base-content">
                    {meal.priceStudents.toFixed(2)} €
                  </span>
                </a>
              </li>
            ))
          )}
        </ul>
      ))
    }
  </div>
</section>

<script>
  document.querySelectorAll("[data-mensa-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const loc = (btn as HTMLElement).dataset.loc

      document.querySelectorAll("[data-mensa-btn]").forEach((b) => {
        b.classList.remove("bg-base-100", "text-base-content", "shadow-sm")
        b.classList.add("text-base-content/70")
      })
      btn.classList.remove("text-base-content/70")
      btn.classList.add("bg-base-100", "text-base-content", "shadow-sm")

      document.querySelectorAll("[id^='meals-']").forEach((el) => {
        ;(el as HTMLElement).hidden = true
      })
      const target = document.getElementById(`meals-${loc}`)
      if (target) target.hidden = false
    })
  })
</script>
