---
import { fetchMensaMeals } from "@/utils/api"
import dayjs from "dayjs"
import { useTranslations } from "@/i18n/translations"
import IconUtensils from "./icons/IconUtensils.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"

const t = useTranslations(Astro.locals.locale)

const CLOSING_HOUR = 15
const CLOSING_MINUTE = 0

function getRelevantDay(): dayjs.Dayjs {
  const now = dayjs()
  const dow = now.day() // 0 = Sunday, 6 = Saturday

  if (dow >= 1 && dow <= 5) {
    const closed =
      now.hour() > CLOSING_HOUR || (now.hour() === CLOSING_HOUR && now.minute() >= CLOSING_MINUTE)
    if (!closed) return now
    // After closing: skip to next weekday (Friday → Monday)
    return now.add(dow === 5 ? 3 : 1, "day")
  }

  if (dow === 6) return now.add(2, "day") // Saturday → Monday
  return now.add(1, "day") // Sunday → Monday
}

const now = dayjs()
const relevantDay = getRelevantDay()
const isToday = relevantDay.isSame(now, "day")
const relevantDayId = relevantDay.format("YYYY-MM-DD")
const relevantDayFormatted = relevantDay.toDate().toLocaleDateString(t.mensa.dateLocale, {
  day: "numeric",
  month: "long",
})

const locations = [
  { id: "feki", label: "Feki", strapiName: "Feki" },
  { id: "austrasse", label: "Austraße", strapiName: "Austraße" },
  { id: "erba", label: "Erba", strapiName: "Erba" },
] as const

const meals = await fetchMensaMeals(relevantDay)

const mealsByLocation = Object.fromEntries(
  locations.map((loc) => [loc.id, meals.filter((m) => m.location === loc.strapiName)])
)
---

<section class="mb-12" id="mensa">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-orange-100">
        <IconUtensils class="h-5 w-5 text-orange-700" />
      </div>
      <div>
        <a href="/mensa" class="text-xl font-semibold hover:text-primary no-underline"
          >{t.mensa.cardTitle}</a
        >
        <p class="text-sm text-base-content/60">
          {
            isToday
              ? t.mensa.cardSubtitleToday(relevantDayFormatted)
              : t.mensa.cardSubtitle(relevantDayFormatted)
          }
        </p>
      </div>
    </div>
    <a href="/mensa" class="btn btn-ghost btn-sm flex gap-1">
      {t.mensa.fullPlan}
      <IconArrowRight class="h-4 w-4" />
    </a>
  </div>

  <div class="rounded-xl border border-base-300 bg-base-100 p-4 sm:p-6">
    <!-- Tab buttons -->
    <div class="mb-4 flex gap-1 rounded-lg bg-base-200 p-1">
      {
        locations.map((loc, i) => (
          <button
            type="button"
            data-mensa-btn
            data-loc={loc.id}
            class:list={[
              "flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-all",
              i === 0
                ? "bg-base-100 text-base-content shadow-sm"
                : "text-base-content/60 hover:text-base-content",
            ]}>
            {loc.label}
          </button>
        ))
      }
    </div>

    <!-- Meal lists -->
    {
      locations.map((loc, i) => (
        <ul id={`meals-${loc.id}`} hidden={i !== 0} class="flex flex-col gap-2">
          {mealsByLocation[loc.id].length === 0 ? (
            <li class="text-base-content/60 text-sm">{t.mensa.noData}</li>
          ) : (
            mealsByLocation[loc.id].map((meal) => (
              <li>
                <a
                  href={`/mensa#${relevantDayId}-${loc.id}`}
                  class="flex items-center justify-between gap-3 rounded-lg border border-base-300 p-3 transition-colors hover:bg-base-200 no-underline">
                  <div class="flex min-w-0 flex-wrap items-center gap-1.5">
                    <span class="text-sm text-base-content">{meal.name}</span>
                    {meal.isVegan && (
                      <span class="inline-flex shrink-0 items-center gap-1 rounded-md bg-emerald-100 px-1.5 py-0.5 text-xs font-medium text-emerald-800">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="h-3 w-3"
                          aria-hidden="true">
                          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
                          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
                        </svg>
                        Vegan
                      </span>
                    )}
                    {!meal.isVegan && meal.isVegetarian && (
                      <span class="inline-flex shrink-0 items-center gap-1 rounded-md bg-green-100 px-1.5 py-0.5 text-xs font-medium text-green-800">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="h-3 w-3"
                          aria-hidden="true">
                          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
                          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
                        </svg>
                        Vegetarisch
                      </span>
                    )}
                  </div>
                  <span class="shrink-0 font-semibold text-sm text-base-content">
                    {meal.priceStudents.toFixed(2)} €
                  </span>
                </a>
              </li>
            ))
          )}
        </ul>
      ))
    }
  </div>
</section>

<script>
  document.querySelectorAll("[data-mensa-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const loc = (btn as HTMLElement).dataset.loc!

      document.querySelectorAll("[data-mensa-btn]").forEach((b) => {
        b.classList.remove("bg-base-100", "text-base-content", "shadow-sm")
        b.classList.add("text-base-content/60")
      })
      btn.classList.remove("text-base-content/60")
      btn.classList.add("bg-base-100", "text-base-content", "shadow-sm")

      document.querySelectorAll("[id^='meals-']").forEach((el) => {
        ;(el as HTMLElement).hidden = true
      })
      const target = document.getElementById(`meals-${loc}`)
      if (target) target.hidden = false
    })
  })
</script>
