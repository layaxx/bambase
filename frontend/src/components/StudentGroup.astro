---
interface Props {
  group: {
    id: string;
    name: string;
    description: string;
    links: { website?: string; email?: string };
  };
}

const { group } = Astro.props;
---

<div data-student-group>
  <h2 class="text-xl font-semibold md:min-h-18 mb-1">
    <a href="#" class="hover:underline">{group.name}</a>
  </h2>

  <p
    data-description
    class="text-sm text-base-content/60"
    style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:5; -webkit-box-orient:vertical;"
  >
    {group.description}
  </p>

  <button data-expand-btn class="btn btn-ghost btn-xs px-0 text-blue-600 h-auto min-h-0 my-1">
    Komplette Beschreibung anzeigen
  </button>

  <div class="flex gap-4 border-t-2 border-base-content/30 pt-2">
    {
      group.links.website && (
        <a
          href={group.links.website}
          target="_blank"
          rel="noopener noreferrer"
          class="link link-hover text-blue-600">
          Website
        </a>
      )
    }
    {
      group.links.email && (
        <a href={`mailto:${group.links.email}`} class="link link-hover text-blue-600">
          E-Mail
        </a>
      )
    }
  </div>
</div>

<script>
  // Deduplicated by Astro — runs once for all instances
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("[data-expand-btn]");
    if (!btn) return;
    const group = btn.closest("[data-student-group]")!;
    const desc = group.querySelector("[data-description]") as HTMLElement;
    const isCollapsed = !!desc.style.webkitLineClamp;
    if (isCollapsed) {
      desc.style.cssText = "";
      btn.textContent = "Beschreibung einklappen";
    } else {
      desc.style.cssText =
        "overflow:hidden; display:-webkit-box; -webkit-line-clamp:5; -webkit-box-orient:vertical;";
      btn.textContent = "Komplette Beschreibung anzeigen";
    }
  });
</script>
