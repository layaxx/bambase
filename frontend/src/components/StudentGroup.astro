---
import IconGlobe from "./icons/IconGlobe.astro"
import IconMail from "./icons/IconMail.astro"

import type { StudentGroup } from "@/utils/api"

interface Props {
  group: StudentGroup
}

const { group } = Astro.props
---

<div
  class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md h-full"
  data-student-group
>
  <h3 class="mb-2 font-semibold leading-tight text-base-content group-hover:text-primary">
    <a class="no-underline" href="#">{group.name}</a>
  </h3>

  <p class="mb-2 text-sm text-base-content/70 line-clamp-4" data-description>
    {group.description}
  </p>

  <button class="btn btn-ghost btn-xs px-0 mb-3 self-start text-primary" data-expand-btn>
    Mehr anzeigen
  </button>

  <div class="mt-auto flex gap-3 border-t border-base-300 pt-3">
    {
      group.website && (
        <a
          class="flex items-center gap-1 text-xs text-base-content/70 hover:text-primary no-underline transition-colors"
          href={group.website}
          rel="noopener noreferrer"
          target="_blank"
        >
          <IconGlobe class="h-3.5 w-3.5" />
          Website
        </a>
      )
    }
    {
      group.email && (
        <a
          class="flex items-center gap-1 text-xs text-base-content/70 hover:text-primary no-underline transition-colors"
          href={`mailto:${group.email}`}
        >
          <IconMail class="h-3.5 w-3.5" />
          E-Mail
        </a>
      )
    }
  </div>
</div>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("[data-expand-btn]")
    if (!btn) return
    const group = btn.closest("[data-student-group]")!
    const desc = group.querySelector("[data-description]") as HTMLElement
    const isCollapsed = desc.classList.contains("line-clamp-4")
    desc.classList.toggle("line-clamp-4", !isCollapsed)
    btn.textContent = isCollapsed ? "Weniger anzeigen" : "Mehr anzeigen"
  })
</script>
