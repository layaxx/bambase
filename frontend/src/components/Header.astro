---
import IconSun from "../icons/IconSun.astro"
import IconMoon from "../icons/IconMoon.astro"
import IconMenu from "../icons/IconMenu.astro"
import IconX from "../icons/IconX.astro"

const navItems = [
  { name: "Jobs", href: "/jobs" },
  { name: "Termine", href: "/events" },
  { name: "Mensaplan", href: "/mensa" },
  { name: "Infomap", href: "/infomap" },
  { name: "Start ins Studium", href: "/start-ins-studium" },
]

const pathname = Astro.url.pathname
const isActive = (href: string) => pathname === href || pathname.startsWith(href + "/")

const authUserRaw = Astro.cookies.get("auth_user")?.value
const authUser = authUserRaw ? JSON.parse(authUserRaw) : null
---

<header class="border-b border-base-300 bg-base-100">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Main header row -->
    <div class="flex h-16 items-center justify-between gap-4">
      <!-- Logo -->
      <a
        href="/"
        class="text-2xl font-extrabold no-underline leading-none shrink-0"
        style="font-family: 'Archivo Variable', sans-serif;"
      >
        BamBase.de
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "px-3 py-1.5 rounded-md text-sm no-underline transition-colors",
                isActive(item.href)
                  ? "font-semibold bg-base-200 text-base-content"
                  : "text-base-content/60 hover:text-base-content hover:bg-base-200",
              ]}>
              {item.name}
            </a>
          ))
        }
      </nav>

      <!-- Right controls -->
      <div class="flex items-center gap-2 shrink-0">
        <input
          class="input input-bordered input-sm hidden md:block w-40 lg:w-56"
          placeholder="Suchen..."
        />
        {
          authUser ? (
            <div class="hidden md:flex">
              <a href="/account" class="btn btn-sm btn-ghost">
                Mein Konto
              </a>
            </div>
          ) : (
            <a href="/login" class="btn btn-sm hidden md:flex">
              Einloggen
            </a>
          )
        }
        <button
          id="theme-toggle"
          aria-label="Dunkelmodus umschalten"
          class="btn btn-ghost btn-sm btn-square"
        >
          <IconSun id="icon-sun" class="hidden size-5" />
          <IconMoon id="icon-moon" class="size-5" />
        </button>
        <button
          id="menu-toggle"
          aria-label="Menü öffnen"
          aria-expanded="false"
          class="btn btn-square btn-sm md:hidden"
        >
          <IconMenu id="icon-menu" class="size-5" />
          <IconX id="icon-x" class="hidden size-5" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" hidden class="border-t border-base-300 px-4 py-3">
    <nav class="flex flex-col gap-1 mb-3">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "px-3 py-2 rounded-md text-sm no-underline transition-colors",
              isActive(item.href)
                ? "font-semibold bg-base-200 text-base-content"
                : "text-base-content/60 hover:text-base-content hover:bg-base-200",
            ]}>
            {item.name}
          </a>
        ))
      }
    </nav>
    <input class="input input-bordered input-sm w-full" placeholder="Suchen..." />
    <div class="mt-3 flex flex-col gap-1">
      {
        authUser ? (
          <a href="/account" class="btn btn-sm btn-ghost w-full">
            Mein Konto
          </a>
        ) : (
          <a href="/login" class="btn btn-sm btn-primary w-full">
            Einloggen
          </a>
        )
      }
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")!
  const nav = document.getElementById("mobile-nav")!
  const iconMenu = document.getElementById("icon-menu")!
  const iconX = document.getElementById("icon-x")!

  toggle.addEventListener("click", () => {
    const isOpen = !nav.hidden
    nav.hidden = isOpen
    toggle.setAttribute("aria-expanded", String(!isOpen))
    toggle.setAttribute("aria-label", isOpen ? "Menü öffnen" : "Menü schließen")
    iconMenu.classList.toggle("hidden", !isOpen)
    iconX.classList.toggle("hidden", isOpen)
  })

  const themeToggle = document.getElementById("theme-toggle")!
  const iconSun = document.getElementById("icon-sun")!
  const iconMoon = document.getElementById("icon-moon")!

  function applyTheme(theme: string) {
    document.documentElement.setAttribute("data-theme", theme)
    localStorage.setItem("theme", theme)
    iconSun.classList.toggle("hidden", theme !== "dark")
    iconMoon.classList.toggle("hidden", theme === "dark")
  }

  applyTheme(document.documentElement.getAttribute("data-theme") ?? "light")

  themeToggle.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme")
    applyTheme(current === "dark" ? "light" : "dark")
  })
</script>
