---
import IconSun from "./icons/IconSun.astro"
import IconMoon from "./icons/IconMoon.astro"
import IconMenu from "./icons/IconMenu.astro"
import IconX from "./icons/IconX.astro"
import IconGitHub from "./icons/IconGitHub.astro"
import { useTranslations } from "@/i18n/translations"

const locale = Astro.locals.locale
const t = useTranslations(locale)

const navItems = [
  { name: t.nav.jobs, href: "/jobs" },
  { name: t.nav.events, href: "/events" },
  { name: t.nav.mensa, href: "/mensa" },
  { name: t.nav.infomap, href: "/map" },
]

const pathname = Astro.url.pathname
const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`)

const authUserRaw = Astro.cookies.get("auth_user")?.value
const authUser = authUserRaw ? JSON.parse(authUserRaw) : null

const switchLang = t.language.switchLang
const switchLabel = t.language.switchLabel
const switchAccessibleLabel = t.language.switchAccessibleLabel
const switchUrl = `/set-locale?lang=${switchLang}&redirect=${encodeURIComponent(pathname)}`
---

<header class="border-b border-base-300 bg-base-100">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Main header row -->
    <div class="flex h-16 items-center justify-between gap-4">
      <!-- Logo -->
      <a
        class="text-2xl font-extrabold no-underline leading-none shrink-0"
        href="/"
        style="font-family: 'Archivo Variable', sans-serif;"
      >
        BamBase.de
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {
          navItems.map((item) => (
            <a
              class:list={[
                "px-3 py-1.5 rounded-md text-sm no-underline transition-colors",
                {
                  "font-semibold bg-base-200 text-base-content": isActive(item.href),
                  "text-base-content/60 hover:text-base-content hover:bg-base-200": !isActive(
                    item.href
                  ),
                },
              ]}
              href={item.href}
            >
              {item.name}
            </a>
          ))
        }
      </nav>

      <!-- Right controls -->
      <div class="flex items-center gap-2 shrink-0">
        <a
          aria-label="GitHub"
          class="btn btn-ghost btn-sm btn-square hidden md:flex"
          href="https://github.com/layaxx/bambase"
          rel="noopener noreferrer"
          target="_blank"
        >
          <IconGitHub class="size-5" />
        </a>
        {
          authUser ? (
            <div class="hidden md:flex">
              <a class="btn btn-sm btn-ghost" href="/account">
                {t.nav.myAccount}
              </a>
            </div>
          ) : (
            <a class="btn btn-sm hidden md:flex" href="/login">
              {t.nav.login}
            </a>
          )
        }
        <a
          aria-label={switchAccessibleLabel}
          class="btn btn-ghost btn-sm font-medium text-xs"
          href={switchUrl}
        >
          {switchLabel}
        </a>
        <button
          aria-label={t.nav.toggleDark}
          class="btn btn-ghost btn-sm btn-square"
          id="theme-toggle"
        >
          <IconSun class="hidden size-5" id="icon-sun" />
          <IconMoon class="size-5" id="icon-moon" />
        </button>
        <button
          aria-expanded="false"
          aria-label={t.nav.openMenu}
          class="btn btn-square btn-sm md:hidden"
          id="menu-toggle"
        >
          <IconMenu class="size-5" id="icon-menu" />
          <IconX class="hidden size-5" id="icon-x" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div class="border-t border-base-300 px-4 py-3" hidden id="mobile-nav">
    <nav class="flex flex-col gap-1 mb-3">
      {
        navItems.map((item) => (
          <a
            class:list={[
              "px-3 py-2 rounded-md text-sm no-underline transition-colors",
              {
                "font-semibold bg-base-200 text-base-content": isActive(item.href),
                "text-base-content/60 hover:text-base-content hover:bg-base-200": !isActive(
                  item.href
                ),
              },
            ]}
            href={item.href}
          >
            {item.name}
          </a>
        ))
      }
    </nav>
    <div class="mt-3 flex flex-col gap-1">
      {
        authUser ? (
          <a class="btn btn-sm btn-ghost w-full" href="/account">
            {t.nav.myAccount}
          </a>
        ) : (
          <a class="btn btn-sm btn-primary w-full" href="/login">
            {t.nav.login}
          </a>
        )
      }
      <a
        class="btn btn-sm btn-ghost w-full"
        href="https://github.com/layaxx/bambase"
        rel="noopener noreferrer"
        target="_blank"
      >
        GitHub
      </a>
    </div>
  </div>
</header>

<script define:vars={{ openMenu: t.nav.openMenu, closeMenu: t.nav.closeMenu }} is:inline>
  const toggle = document.getElementById("menu-toggle")
  const nav = document.getElementById("mobile-nav")
  const iconMenu = document.getElementById("icon-menu")
  const iconX = document.getElementById("icon-x")

  toggle.addEventListener("click", () => {
    const isOpen = !nav.hidden
    nav.hidden = isOpen
    toggle.setAttribute("aria-expanded", String(!isOpen))
    toggle.setAttribute("aria-label", isOpen ? openMenu : closeMenu)
    iconMenu.classList.toggle("hidden", !isOpen)
    iconX.classList.toggle("hidden", isOpen)
  })

  const themeToggle = document.getElementById("theme-toggle")
  const iconSun = document.getElementById("icon-sun")
  const iconMoon = document.getElementById("icon-moon")

  function applyTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme)
    localStorage.setItem("theme", theme)
    iconSun.classList.toggle("hidden", theme !== "dark")
    iconMoon.classList.toggle("hidden", theme === "dark")
  }

  applyTheme(document.documentElement.getAttribute("data-theme") ?? "light")

  themeToggle.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme")
    applyTheme(current === "dark" ? "light" : "dark")
  })
</script>
