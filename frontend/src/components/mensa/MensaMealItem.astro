---
import type { MensaMeal } from "@/utils/api"
import IconChevronRight from "@/components/icons/IconChevronRight.astro"
import MealBadge from "./MealBadge.astro"

interface Props {
  meal: MensaMeal
  id?: string
}

const { meal, id } = Astro.props
---

<li
  class="flex flex-col gap-2 rounded-lg border border-base-300 p-3 transition-colors hover:bg-base-200"
  id={id}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex min-w-0 flex-wrap items-center gap-1.5">
      <span class="text-sm leading-snug text-base-content">{meal.name}</span>
      {meal.isVegan && <MealBadge type="vegan" />}
      {meal.isVegetarian && !meal.isVegan && <MealBadge type="vegetarian" />}
    </div>
    <span class="shrink-0 font-semibold text-sm text-base-content">
      {meal.priceStudents.toFixed(2)} €
    </span>
  </div>

  {
    meal.allergens && meal.allergens.length > 0 && (
      <details class="group/allergens">
        <summary class="cursor-pointer list-none">
          <span class="flex w-fit items-center gap-1 text-xs text-base-content/40 transition-colors hover:text-base-content/70">
            <IconChevronRight class="h-3 w-3 transition-transform group-open/allergens:rotate-90" />
            Allergene anzeigen
          </span>
        </summary>
        <div class="mt-1.5 flex flex-wrap gap-1">
          {meal.allergens.map((a) => (
            <span class="rounded bg-base-200 px-1.5 py-0.5 text-xs text-base-content/70">
              {a.name}
            </span>
          ))}
        </div>
      </details>
    )
  }
</li>

<style>
  li:target {
    box-shadow: 0 0 0 2px var(--color-primary);
  }
</style>
