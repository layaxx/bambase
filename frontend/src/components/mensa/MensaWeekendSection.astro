---
import IconUtensils from "@/components/icons/IconUtensils.astro"
import IconX from "@/components/icons/IconX.astro"

interface Props {
  id: string
  heading: string
}

const { id, heading } = Astro.props
---

<section id={id}>
  <div class="mb-4 flex items-center gap-3">
    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-base-200">
      <IconUtensils class="h-5 w-5 text-base-content/40" />
    </div>
    <h2 class="text-xl font-semibold text-base-content">{heading}</h2>
  </div>

  <div class="rounded-xl border border-base-300 bg-base-100 p-8 text-center text-base-content/70">
    <IconX class="mx-auto mb-3 h-8 w-8 opacity-40" />
    <p class="text-sm font-medium">Am Wochenende geschlossen</p>
    <p class="mt-1 text-xs">Die Bamberger Mensen haben samstags und sonntags nicht geöffnet.</p>
  </div>
</section>
