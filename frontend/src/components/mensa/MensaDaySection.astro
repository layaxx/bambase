---
import type { MensaMeal } from "@/utils/api"
import MensaLocationCard from "@/components/mensa/MensaLocationCard.astro"
import { useTranslations } from "@/i18n/translations"
import IconUtensils from "@/components/icons/IconUtensils.astro"
import IconMinusCircle from "@/components/icons/IconMinusCircle.astro"

interface Props {
  id: string
  heading: string
  meals: MensaMeal[]
}

const { id, heading, meals } = Astro.props
const t = useTranslations(Astro.locals.locale)

const locations = [
  { id: "feki", label: "Feki", strapiName: "Feki" },
  { id: "austrasse", label: "Austraße", strapiName: "Austraße" },
  { id: "erba", label: "Erba", strapiName: "Erba" },
] as const

const mealsByLocation = Object.fromEntries(
  locations.map((loc) => [
    loc.id,
    meals
      .filter((m) => m.location === loc.strapiName)
      .sort((a, b) => a.priceStudents - b.priceStudents),
  ])
)
---

<section id={id}>
  <div class="mb-4 flex items-center gap-3">
    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-warning/20">
      <IconUtensils class="h-5 w-5 text-warning" />
    </div>
    <h2 class="text-xl font-semibold text-base-content">{heading}</h2>
  </div>

  {
    meals.length === 0 ? (
      <div class="rounded-xl border border-base-300 bg-base-100 p-8 text-center text-base-content/60">
        <IconMinusCircle class="mx-auto mb-3 h-8 w-8 opacity-40" />
        <p class="text-sm">{t.mensa.noDataDay}</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {locations.map((loc) => (
          <MensaLocationCard
            id={`${id}-${loc.id}`}
            label={loc.label}
            meals={mealsByLocation[loc.id]}
          />
        ))}
      </div>
    )
  }
</section>
