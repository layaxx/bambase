---
import type { Event } from "@/utils/api/events"
import { formatTime } from "@/utils/event-formatting"
import { useTranslations } from "@/i18n/translations"
import IconClock from "./icons/IconClock.astro"

interface Props {
  event: Event
  short?: boolean
}

const { event, short = false } = Astro.props
const t = useTranslations(Astro.locals.locale)
const dateLocale = t.mensa.dateLocale
---

<a
  class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 no-underline transition-all hover:shadow-md"
  href={`/event/${event.slug}`}
>
  <div class="mb-3 flex flex-row-reverse justify-between">
    <span class="badge badge-soft badge-sm">{t.events.categories[event.category]}</span>
    <div class="flex items-center gap-1 text-sm text-base-content/70">
      <IconClock class="h-3.5 w-3.5 shrink-0" />
      <span>
        {formatTime(event.start, dateLocale)}
        {t.events.clock ? ` ${t.events.clock}` : ""}
        {
          !short && (
            <>
              {" "}
              – {formatTime(event.end, dateLocale)}
              {t.events.clock ? ` ${t.events.clock}` : ""}
            </>
          )
        }
      </span>
    </div>
  </div>
  <h3
    class:list={[
      "font-semibold leading-tight text-base-content group-hover:text-primary",
      { "mb-2": short, "mb-1": !short },
    ]}
  >
    {event.title}
  </h3>
  {!short && <p class="mb-3 line-clamp-2 text-sm text-base-content/70">{event.description}</p>}
  <div
    class:list={[
      "mt-auto text-sm text-base-content/70",
      { truncate: short, "flex items-center justify-between gap-2": !short },
    ]}
  >
    <span class="truncate">{event.organizer}</span>
    {
      !short && event.external_url && (
        <a
          class="shrink-0 text-primary hover:underline"
          href={event.external_url}
          rel="noopener noreferrer"
          target="_blank"
        >
          ↗
        </a>
      )
    }
  </div>
</a>
