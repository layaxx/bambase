---
import IconGlobe from "./icons/IconGlobe.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"

const sidebarLinks = [
  "FS WIAI - Jobbörse",
  "FS SOWI - Terminkalender",
  "FS HUWI",
  "FS GuK",
  "USI e.V. - Wandkalender",
  "... und viele weitere!",
]
---

<div class="flex flex-col gap-4 max-md:order-first md:row-span-2 md:col-start-3">
  <div class="rounded-xl border border-base-300 bg-base-100 overflow-hidden">
    <div class="bg-base-200 px-4 py-3">
      <h2 class="font-semibold text-base-content">Über uns</h2>
    </div>
    <div class="p-4">
      <p class="text-sm text-base-content/60">
        Unser Ziel ist es, Bamberger Studierenden eine zentrale Anlaufstelle für alle wichtigen
        Informationen rund ums Studium zu bieten.
      </p>
    </div>
  </div>

  <div class="rounded-xl border border-base-300 bg-base-100 p-4">
    <h3 class="mb-3 text-sm font-semibold text-base-content">Entwicklung &amp; Betrieb</h3>
    <ul class="mb-4 flex flex-col gap-2 text-sm">
      <li>
        <a
          href="#"
          class="flex items-center gap-1.5 text-base-content/60 hover:text-primary no-underline transition-colors"
        >
          <IconGlobe class="h-3.5 w-3.5 shrink-0" />
          Platzhalter e. V.
        </a>
      </li>
    </ul>

    <h3 class="mb-3 text-sm font-semibold text-base-content">Teilverantwortliche Gruppen</h3>
    <ul class="flex flex-col gap-2 text-sm">
      {
        sidebarLinks.map((name) => (
          <li>
            <a
              href="#"
              class="flex items-center gap-1.5 text-base-content/60 hover:text-primary no-underline transition-colors">
              <IconArrowRight class="h-3.5 w-3.5 shrink-0" />
              {name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>
