---
import { formatDate, formatTime } from "@/utils/event-formatting"
import IconArrowLeft from "../icons/IconArrowLeft.astro"
import { useTranslations } from "@/i18n/translations"
import IconCalendar from "../icons/IconCalendar.astro"
import IconClock from "../icons/IconClock.astro"
import IconExternalLink from "../icons/IconExternalLink.astro"
import IconSliders from "../icons/IconSliders.astro"
import IconUsers from "../icons/IconUsers.astro"
import ReportModal from "../ReportModal.astro"
import EventCategoryBadge from "./EventCategoryBadge.astro"
import type { Event } from "@/utils/api/events"
import IconMapPin from "../icons/IconMapPin.astro"
import { formatAddress } from "@/utils/map"

type Props = {
  event: Event
  isOwner: boolean | undefined
  hasReports: boolean
  hasBeenReported: string | null
}

const { event, isOwner, hasReports, hasBeenReported } = Astro.props

const t = useTranslations(Astro.locals.locale)
const dateLocale = t.mensa.dateLocale

const formattedEventDate = event ? formatDate(event.start, dateLocale) : null

const location = event?.map_location ?? event?.custom_location
---

<>
  <div class="mb-6 flex items-center justify-between gap-4">
    <a class="btn btn-ghost btn-sm gap-1 pl-0" href="/events">
      <IconArrowLeft class="h-4 w-4" />
      {t.events.backToEvents}
    </a>
    {
      isOwner && (
        <div class="flex items-center gap-2">
          <a class="btn btn-ghost btn-sm" href="/account/events">
            {t.auth.myEvents}
          </a>
          <a class="btn btn-outline btn-sm" href={`/event/${event.slug}/edit`}>
            {t.events.editEvent}
          </a>
          <button
            class="btn btn-outline btn-error btn-sm"
            onclick="document.getElementById('deleteEventModal').showModal()"
            type="button"
          >
            {t.events.deleteEvent}
          </button>
        </div>
      )
    }
  </div>

  {
    hasReports && (
      <div class="alert alert-warning alert-outline mb-6" role="alert">
        <span>{t.reports.warningHint}</span>
      </div>
    )
  }

  {
    hasBeenReported === "success" && (
      <div class="alert alert-success mb-6" role="alert">
        <span>{t.reports.successMessage}</span>
      </div>
    )
  }

  {
    hasBeenReported === "error" && (
      <div class="alert alert-error mb-6" role="alert">
        <span>{t.reports.errorMessage}</span>
      </div>
    )
  }

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">{event.title}</h1>

      <div class="mb-6 flex flex-wrap gap-x-5 gap-y-2 text-sm text-base-content/70">
        <div class="flex items-center gap-1.5">
          <IconCalendar class="h-4 w-4 shrink-0" />
          <span>{formattedEventDate}</span>
        </div>
        <div class="flex items-center gap-1.5">
          <IconClock class="h-4 w-4 shrink-0" />
          <span>
            {formatTime(event.start, dateLocale)}
            {" – "}
            {formatTime(event.end, dateLocale)}
            {t.events.clock ? ` ${t.events.clock}` : ""}
          </span>
        </div>
      </div>

      <div class="prose prose-sm max-w-none text-base-content/70">
        <p class="whitespace-pre-wrap">{event.description}</p>
      </div>

      {
        event.external_id && (
          <p class="text-xs text-base-content/40 border-t border-base-300 mt-4 pt-1">
            {event.external_id.startsWith("univis:")
              ? t.events.syncedFromUnivis
              : t.events.syncedFromExternal}
          </p>
        )
      }
    </div>

    <aside class="flex flex-col gap-4">
      <div class="rounded-xl border border-base-300 bg-base-100 p-5">
        <dl class="flex flex-col gap-4 text-sm">
          <div class="flex items-start gap-2">
            <IconSliders class="mt-0.5 h-4 w-4 shrink-0 text-base-content/40" />
            <div class="min-w-0">
              <dt class="mb-0.5 text-xs text-base-content/70">{t.events.filterCategory}</dt>
              <dd>
                <a href={`/events?category=${event.category}`}
                  ><EventCategoryBadge category={event.category} /></a
                >
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-2">
            <IconCalendar class="mt-0.5 h-4 w-4 shrink-0 text-base-content/40" />
            <div class="min-w-0">
              <dt class="mb-0.5 text-xs text-base-content/70">{t.events.date}</dt>
              <dd class="font-medium">{formattedEventDate}</dd>
              <dd class="text-base-content/70">
                {formatTime(event.start, dateLocale)}
                {" – "}
                {formatTime(event.end, dateLocale)}
                {t.events.clock ? ` ${t.events.clock}` : ""}
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-2">
            <IconUsers class="mt-0.5 h-4 w-4 shrink-0 text-base-content/40" />
            <div class="min-w-0">
              <dt class="mb-0.5 text-xs text-base-content/70">{t.events.organizer}</dt>
              <dd class="font-medium">{event.organizer}</dd>
            </div>
          </div>

          {
            location && (
              <div class="flex items-start gap-2">
                <IconMapPin class="mt-0.5 h-4 w-4 shrink-0 text-base-content/40" />
                <div class="min-w-0">
                  <dt class="mb-0.5 text-xs text-base-content/70">{t.events.locationLabel}</dt>
                  <dd class="font-medium">{location.name}</dd>
                  <p class="mt-0.5 text-xs text-base-content/70">
                    {location.address &&
                      typeof location.address === "object" &&
                      formatAddress(location.address)}
                    {location.address && typeof location.address === "string" && location.address}
                  </p>
                  {"category" in location && location.category && (
                    <a
                      class="mt-1 inline-flex items-center gap-1 text-xs text-primary hover:underline"
                      href={`/map?filter=${location.category}`}
                    >
                      {t.events.viewOnMap}
                    </a>
                  )}
                </div>
              </div>
            )
          }
        </dl>
      </div>

      {
        event.external_url && (
          <a
            class="btn btn-primary w-full"
            href={event.external_url}
            rel="noopener noreferrer"
            target="_blank"
          >
            {t.events.moreInfo}
            <IconExternalLink class="h-4 w-4" />
          </a>
        )
      }

      <div class="rounded-xl border border-base-300 bg-base-100 p-4 text-sm text-base-content/70">
        <p>{t.reports.eventDisclaimer}</p>
        {
          !isOwner && !hasBeenReported && (
            <div class="mt-2 flex justify-end">
              <ReportModal targetId={event.documentId} targetType="event" />
            </div>
          )
        }
      </div>
    </aside>
  </div>
</>
