---
import type { JobOffer } from "@/utils/api/job-offers"
import { useTranslations } from "@/i18n/translations"
import IconStore from "./icons/IconStore.astro"
import IconMapPin from "./icons/IconMapPin.astro"

interface Props {
  job: JobOffer
}

const { job } = Astro.props
const t = useTranslations(Astro.locals.locale)
---

<a
  class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md no-underline"
  href={`/job/${job.uuid}`}
>
  <h3 class="mb-1 font-semibold leading-tight text-base-content group-hover:text-primary">
    {job.title}
  </h3>
  <div class="mb-2 flex flex-row-reverse justify-between">
    <span class="badge badge-soft badge-sm">{t.jobs.jobTypes[job.job_type]}</span>
    <div class="flex items-center gap-1.5 text-sm text-base-content/60">
      <IconStore class="h-3.5 w-3.5 shrink-0" />
      <span class="truncate">{job.company}</span>
    </div>
  </div>
  <p class="mb-3 line-clamp-2 text-sm text-base-content/60">{job.description}</p>
  <div class="mt-auto flex items-center justify-between gap-2 text-sm text-base-content/60">
    <div class="flex items-center gap-1.5">
      <IconMapPin class="h-3.5 w-3.5 shrink-0" />
      <span class="truncate">{job.location}</span>
    </div>
    <span class="shrink-0">{t.jobs.workingHours(job.working_hours)}</span>
  </div>
</a>
