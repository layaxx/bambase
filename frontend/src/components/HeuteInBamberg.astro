---
import { fetchEvents } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconCalendar from "./icons/IconCalendar.astro"
import IconClock from "./icons/IconClock.astro"
import IconArrowRight from "./icons/IconArrowRight.astro"

const t = useTranslations(Astro.locals.locale)

const todayStr = new Date().toISOString().split("T")[0]
const allEvents = await fetchEvents()
const todayEvents = allEvents.filter((e) => e.start.startsWith(todayStr))

function formatTime(iso: string) {
  return new Date(iso).toLocaleTimeString(t.mensa.dateLocale, {
    hour: "2-digit",
    minute: "2-digit",
  })
}
---

<!-- Events Section -->
<section class="mb-12" id="events">
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100">
        <IconCalendar class="h-5 w-5 text-blue-700" />
      </div>
      <div>
        <a href="/events" class="text-xl font-semibold hover:text-primary no-underline"
          >{t.events.title}</a
        >
        <p class="text-sm text-base-content/60">
          {t.events.countToday(todayEvents.length)}
        </p>
      </div>
    </div>
    <a href="/events" class="btn btn-ghost btn-sm flex gap-1">
      {t.events.showAll}
      <IconArrowRight class="h-4 w-4" />
    </a>
  </div>

  {
    todayEvents.length === 0 ? (
      <p class="text-base-content/60 rounded-xl border border-base-300 bg-base-100 p-6">
        {t.events.none}
      </p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {todayEvents.map((event) => (
          <a
            href={`/event/${event.slug}`}
            class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md no-underline">
            <div class="mb-3 flex items-center gap-1 text-sm text-base-content/60">
              <IconClock class="h-3.5 w-3.5 shrink-0" />
              <span>
                {formatTime(event.start)}
                {t.events.clock ? ` ${t.events.clock}` : ""}
              </span>
            </div>
            <h3 class="mb-2 font-semibold leading-tight text-base-content group-hover:text-primary">
              {event.title}
            </h3>
            <div class="mt-auto text-sm text-base-content/60 truncate">{event.organizer}</div>
          </a>
        ))}
      </div>
    )
  }
</section>
