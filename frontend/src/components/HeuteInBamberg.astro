---
import meals from "../data/mensa.json";
import events from "../data/events.json";

const today = new Date();
const todayStr = today.toISOString().split("T")[0];
const todayFormatted = today.toLocaleDateString("de-DE", { day: "numeric", month: "long" });
const todayEvents = events.filter((e) => e.date === todayStr);

const locations = [
  { id: "feki", label: "Feki" },
  { id: "austrasse", label: "Austraße" },
  { id: "erba", label: "Erba" },
] as const;
---

<div class="bg-base-200 rounded-md md:rounded-lg p-3 md:p-6 mb-6">
  <h1 class="text-2xl font-semibold mb-6">Aktuell in Bamberg</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Events card -->
    <div class="card bg-base-100 border border-base-300 min-w-0">
      <div class="card-body p-4 pb-2">
        <div class="flex items-baseline flex-col md:flex-row gap-0 md:gap-4">
          <h2 class="card-title text-xl font-semibold">
            <a href="#" class="hover:underline text-inherit">
              <span class="text-pink-600">EVENTS</span> in Bamberg
            </a>
          </h2>
          <span class="text-base-content/60 text-sm font-mono">(Heute, {todayFormatted})</span>
        </div>
      </div>
      <div class="p-4 pt-2">
        <ul class="flex flex-col gap-1 text-sm">
          {
            todayEvents.length === 0 && (
              <p class="text-base-content/60 text-sm">Keine Veranstaltungen heute.</p>
            )
          }
          {
            todayEvents.map((event) => (
              <li class="overflow-hidden text-ellipsis whitespace-nowrap">
                <a href="#" class="hover:underline">
                  <span class="font-bold">{event.time}</span> {event.title}{" "}
                  <span class="text-base-content/60">({event.location.name})</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Mensa card -->
    <div class="card bg-base-100 border border-base-300 min-w-0">
      <div class="card-body p-4 pb-2">
        <div class="flex items-baseline flex-col md:flex-row gap-0 md:gap-4">
          <h2 class="card-title text-xl font-semibold">
            <a href="#" class="hover:underline text-green-600">MENSAPLAN</a>
          </h2>
          <span class="text-base-content/60 text-sm font-mono">(Morgen, 12. März)</span>
        </div>
        <div class="join mt-2">
          {
            locations.map((loc, i) => (
              <button
                data-mensa-btn
                data-loc={loc.id}
                class:list={["btn btn-xs join-item", i === 0 ? "btn-neutral" : "btn-ghost"]}>
                {loc.label}
              </button>
            ))
          }
        </div>
      </div>
      <div class="p-4 pt-2">
        {
          locations.map((loc, i) => (
            <ul id={`meals-${loc.id}`} hidden={i !== 0} class="flex flex-col gap-1 text-sm">
              {meals[0][loc.id].map((meal) => (
                <li class="overflow-hidden text-ellipsis whitespace-nowrap">
                  <span class="font-bold">{meal.price.toFixed(2)} €</span> {meal.name}
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll("[data-mensa-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const loc = (btn as HTMLElement).dataset.loc!;

      document.querySelectorAll("[data-mensa-btn]").forEach((b) => {
        b.classList.remove("btn-neutral");
        b.classList.add("btn-ghost");
      });
      btn.classList.remove("btn-ghost");
      btn.classList.add("btn-neutral");

      document.querySelectorAll("[id^='meals-']").forEach((el) => {
        (el as HTMLElement).hidden = true;
      });
      const target = document.getElementById(`meals-${loc}`);
      if (target) target.hidden = false;
    });
  });
</script>
