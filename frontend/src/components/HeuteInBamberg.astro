---
import events from "../data/events.json";
import MensaCard from "./MensaCard.astro";

const today = new Date();
const todayStr = today.toISOString().split("T")[0];
const todayFormatted = today.toLocaleDateString("de-DE", { day: "numeric", month: "long" });
const todayEvents = events.filter((e) => e.date === todayStr);
---

<div class="bg-base-200 rounded-md md:rounded-lg p-3 md:p-6 mb-6">
  <h1 class="text-2xl font-semibold mb-6">Aktuell in Bamberg</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Events card -->
    <div class="card bg-base-100 border border-base-300 min-w-0">
      <div class="card-body p-4 pb-2">
        <div class="flex items-baseline flex-col md:flex-row gap-0 md:gap-4">
          <h2 class="card-title text-xl font-semibold">
            <a href="#" class="hover:underline text-inherit">
              <span class="text-pink-600">EVENTS</span> in Bamberg
            </a>
          </h2>
          <span class="text-base-content/60 text-sm font-mono">(Heute, {todayFormatted})</span>
        </div>
      </div>
      <div class="p-4 pt-2">
        <ul class="flex flex-col gap-1 text-sm">
          {
            todayEvents.length === 0 && (
              <p class="text-base-content/60 text-sm">Keine Veranstaltungen heute.</p>
            )
          }
          {
            todayEvents.map((event) => (
              <li class="overflow-hidden text-ellipsis whitespace-nowrap">
                <a href="#" class="hover:underline">
                  <span class="font-bold">{event.time}</span> {event.title}{" "}
                  <span class="text-base-content/60">({event.location.name})</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Mensa card -->
    <MensaCard />
  </div>
</div>
