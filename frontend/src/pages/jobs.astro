---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconBriefcase from "@/components/icons/IconBriefcase.astro"
import JobOfferCard from "@/components/JobOfferCard.astro"
import { fetchJobOffers } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const jobs = await fetchJobOffers()
const isLoggedIn = !!Astro.cookies.get("auth_token")?.value
---

<PageLayout>
  <PageHeader label="Bamberg & Region" subtitle={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
    <IconBriefcase class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/jobs">
            {t.auth.myJobOffers}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/job/new">{t.jobs.postJob}</a>
    </div>
  </PageHeader>

  {
    jobs.length === 0 ? (
      <p class="text-base-content/60">{t.jobs.noJobs}</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {jobs.map((job) => (
          <JobOfferCard job={job} />
        ))}
      </div>
    )
  }
</PageLayout>
