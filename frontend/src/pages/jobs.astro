---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconBriefcase from "@/components/icons/IconBriefcase.astro"
import IconSliders from "@/components/icons/IconSliders.astro"
import IconSearch from "@/components/icons/IconSearch.astro"
import IconX from "@/components/icons/IconX.astro"
import IconCheck from "@/components/icons/IconCheck.astro"
import JobOfferCard from "@/components/jobs/JobOfferCard.astro"
import ApiDownBanner from "@/components/ApiDownBanner.astro"
import Pagination from "@/components/Pagination.astro"
import {
  fetchJobOffersPaginated,
  fetchJobOffers,
  JOB_TYPES,
  JOB_FIELDS,
  WORK_MODES,
  type JobType,
  type JobField,
  type WorkMode,
} from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const PAGE_SIZE = 12

const rawTypes = Astro.url.searchParams.get("type")?.split(",").filter(Boolean) ?? []
const rawFields = Astro.url.searchParams.get("field")?.split(",").filter(Boolean) ?? []
const rawWorkModes = Astro.url.searchParams.get("work_mode")?.split(",").filter(Boolean) ?? []
const search = Astro.url.searchParams.get("search") ?? ""
const sort = Astro.url.searchParams.get("sort") ?? "newest"
const rawPage = parseInt(Astro.url.searchParams.get("page") ?? "1", 10)

const types = rawTypes.filter((v) => (JOB_TYPES as readonly string[]).includes(v)) as JobType[]
const fields = rawFields.filter((v) => (JOB_FIELDS as readonly string[]).includes(v)) as JobField[]
const workModes = rawWorkModes.filter((v) =>
  (WORK_MODES as readonly string[]).includes(v)
) as WorkMode[]
const currentPage = isNaN(rawPage) || rawPage < 1 ? 1 : rawPage

const hasActiveFilter =
  types.length > 0 || fields.length > 0 || workModes.length > 0 || search !== ""

const [{ data, apiDown }, { data: allJobs }] = await Promise.all([
  fetchJobOffersPaginated({
    types,
    fields,
    workModes,
    search,
    sort,
    page: currentPage,
    pageSize: PAGE_SIZE,
  }),
  fetchJobOffers(),
])
const { jobs, total, page: actualPage, pageCount } = data

const typeCounts = Object.fromEntries(
  JOB_TYPES.map((jt) => [jt, allJobs.filter((j) => j.job_type === jt).length])
)
const fieldCounts = Object.fromEntries(
  JOB_FIELDS.map((jf) => [jf, allJobs.filter((j) => j.field === jf).length])
)
const workModeCounts = Object.fromEntries(
  WORK_MODES.map((wm) => [wm, allJobs.filter((j) => j.work_mode === wm).length])
)

if (!apiDown && jobs.length === 0 && total > 0) {
  const redirectParams = new URLSearchParams(Astro.url.searchParams)
  redirectParams.delete("page")
  const qs = redirectParams.toString()
  return Astro.redirect(qs ? `?${qs}` : Astro.url.pathname)
}

const isLoggedIn = !!Astro.locals.user

function buildToggleUrl(param: string, value: string, current: string[]): string {
  const params = new URLSearchParams(Astro.url.searchParams)
  params.delete("page")
  const next = current.includes(value) ? current.filter((v) => v !== value) : [...current, value]
  if (next.length === 0) params.delete(param)
  else params.set(param, next.join(","))
  const qs = params.toString()
  return qs ? `?${qs}` : Astro.url.pathname
}
---

<PageLayout description={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
  <PageHeader color="success" subtitle={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
    <IconBriefcase class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/jobs">
            {t.auth.myJobOffers}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/job/new">{t.jobs.postJob}</a>
    </div>
  </PageHeader>

  {apiDown && <ApiDownBanner />}

  <div class="flex flex-col gap-6 lg:grid lg:grid-cols-[256px_1fr] lg:items-start lg:gap-8">
    <!-- Sidebar filters -->
    <aside class="lg:sticky lg:top-4">
      <div class="mb-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <IconSliders class="h-4 w-4 text-base-content/40" />
          <span class="font-medium">{t.jobs.filterHeading}</span>
        </div>
        {
          hasActiveFilter && (
            <a class="text-sm text-primary hover:underline" href={Astro.url.pathname}>
              {t.jobs.clearFilters}
            </a>
          )
        }
      </div>

      <!-- JOB TYPE -->
      <div class="mb-5">
        <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
          {t.jobs.filterType}
        </h3>
        {
          JOB_TYPES.map((jt) => {
            const checked = types.includes(jt)
            const count = typeCounts[jt] ?? 0
            return (
              <a
                class:list={[
                  "flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors",
                  { "bg-neutral text-neutral-content": checked, "hover:bg-base-200": !checked },
                ]}
                href={buildToggleUrl("type", jt, types)}
              >
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      "flex h-4 w-4 shrink-0 items-center justify-center rounded border",
                      {
                        "border-neutral-content/60 bg-neutral-content/20": checked,
                        "border-base-content/40": !checked,
                      },
                    ]}
                  >
                    {checked && <IconCheck class="h-2.5 w-2.5" />}
                  </span>
                  <span>{t.jobs.jobTypes[jt]}</span>
                </div>
                <span class="text-xs text-base-content/40">{count}</span>
              </a>
            )
          })
        }
      </div>

      <!-- FIELD -->
      <div class="mb-5">
        <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
          {t.jobs.filterField}
        </h3>
        {
          JOB_FIELDS.map((jf) => {
            const checked = fields.includes(jf)
            const count = fieldCounts[jf] ?? 0
            return (
              <a
                class:list={[
                  "flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors",
                  { "bg-neutral text-neutral-content": checked, "hover:bg-base-200": !checked },
                ]}
                href={buildToggleUrl("field", jf, fields)}
              >
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      "flex h-4 w-4 shrink-0 items-center justify-center rounded border",
                      {
                        "border-neutral-content/60 bg-neutral-content/20": checked,
                        "border-base-content/40": !checked,
                      },
                    ]}
                  >
                    {checked && <IconCheck class="h-2.5 w-2.5" />}
                  </span>
                  <span>{t.jobs.jobFields[jf]}</span>
                </div>
                <span class="text-xs text-base-content/40">{count}</span>
              </a>
            )
          })
        }
      </div>

      <!-- WORK MODE -->
      <div class="mb-5">
        <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">
          {t.jobs.fieldWorkMode}
        </h3>
        {
          WORK_MODES.map((wm) => {
            const checked = workModes.includes(wm)
            const count = workModeCounts[wm] ?? 0
            return (
              <a
                class:list={[
                  "flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors",
                  { "bg-neutral text-neutral-content": checked, "hover:bg-base-200": !checked },
                ]}
                href={buildToggleUrl("work_mode", wm, workModes)}
              >
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      "flex h-4 w-4 shrink-0 items-center justify-center rounded border",
                      {
                        "border-neutral-content/60 bg-neutral-content/20": checked,
                        "border-base-content/40": !checked,
                      },
                    ]}
                  >
                    {checked && <IconCheck class="h-2.5 w-2.5" />}
                  </span>
                  <span>{t.jobs.workModes[wm]}</span>
                </div>
                <span class="text-xs text-base-content/40">{count}</span>
              </a>
            )
          })
        }
      </div>
    </aside>

    <!-- Main content -->
    <div>
      <!-- Search + sort row -->
      <div class="mb-4 flex gap-3">
        <div class="relative flex-1">
          <IconSearch
            class="pointer-events-none absolute left-3 top-1/2 z-1 h-4 w-4 -translate-y-1/2 text-base-content/40"
          />
          <input
            class="input input-bordered w-full pl-9"
            id="search-input"
            placeholder={t.jobs.filterSearch}
            type="search"
            value={search}
          />
        </div>
        <select class="select select-bordered shrink-0" id="sort-select">
          <option selected={sort === "newest"} value="newest">{t.jobs.sortNewest}</option>
          <option selected={sort === "oldest"} value="oldest">{t.jobs.sortOldest}</option>
        </select>
      </div>

      <!-- Active filter chips -->
      {
        hasActiveFilter && (
          <div class="mb-4 flex flex-wrap items-center gap-2">
            {types.map((jt) => (
              <a class="badge badge-neutral gap-1 pr-1" href={buildToggleUrl("type", jt, types)}>
                {t.jobs.jobTypes[jt]}
                <IconX class="h-3 w-3" />
              </a>
            ))}
            {fields.map((jf) => (
              <a class="badge badge-neutral gap-1 pr-1" href={buildToggleUrl("field", jf, fields)}>
                {t.jobs.jobFields[jf]}
                <IconX class="h-3 w-3" />
              </a>
            ))}
            {workModes.map((wm) => (
              <a
                class="badge badge-neutral gap-1 pr-1"
                href={buildToggleUrl("work_mode", wm, workModes)}
              >
                {t.jobs.workModes[wm]}
                <IconX class="h-3 w-3" />
              </a>
            ))}
            <a class="text-sm text-primary hover:underline" href={Astro.url.pathname}>
              {t.jobs.clearFilters}
            </a>
          </div>
        )
      }

      <!-- Result count -->
      <p aria-live="polite" class="mb-4 text-sm text-base-content/40">
        {t.jobs.showingResults(jobs.length, total)}
      </p>

      <!-- Job cards or empty state -->
      {
        !apiDown &&
          (jobs.length === 0 ? (
            <div class="rounded-xl border border-base-300 py-16 text-center">
              <IconBriefcase class="mx-auto mb-4 h-10 w-10 text-base-content/40" />
              <p class="mb-1 font-medium">{t.jobs.noJobsFoundTitle}</p>
              <p class="mb-4 text-sm text-base-content/70">{t.jobs.noJobsFoundHint}</p>
              {hasActiveFilter && (
                <a class="btn btn-outline btn-sm" href={Astro.url.pathname}>
                  {t.jobs.clearFilters}
                </a>
              )}
            </div>
          ) : (
            <div class="grid gap-4 sm:grid-cols-2">
              {jobs.map((job) => (
                <JobOfferCard job={job} />
              ))}
            </div>
          ))
      }

      <Pagination
        nextLabel={t.jobs.paginationNext}
        page={actualPage}
        pageCount={pageCount}
        prevLabel={t.jobs.paginationPrev}
      />
    </div>
  </div>
</PageLayout>

<script>
  const searchInput = document.getElementById("search-input") as HTMLInputElement | null
  const sortSelect = document.getElementById("sort-select") as HTMLSelectElement | null

  if (searchInput) {
    if (searchInput.value) {
      searchInput.focus()
      const len = searchInput.value.length
      searchInput.setSelectionRange(len, len)
    }

    let searchTimer: ReturnType<typeof setTimeout>
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimer)
      searchTimer = setTimeout(() => {
        const params = new URLSearchParams(window.location.search)
        const val = searchInput.value.trim()
        if (val) params.set("search", val)
        else params.delete("search")
        params.delete("page")
        const qs = params.toString()
        window.location.href = qs ? `?${qs}` : window.location.pathname
      }, 300)
    })
  }

  if (sortSelect) {
    sortSelect.addEventListener("change", () => {
      const params = new URLSearchParams(window.location.search)
      if (sortSelect.value === "newest") params.delete("sort")
      else params.set("sort", sortSelect.value)
      params.delete("page")
      const qs = params.toString()
      window.location.href = qs ? `?${qs}` : window.location.pathname
    })
  }
</script>
