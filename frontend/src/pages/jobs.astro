---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconBriefcase from "@/components/icons/IconBriefcase.astro"
import IconSliders from "@/components/icons/IconSliders.astro"
import IconChevronDown from "@/components/icons/IconChevronDown.astro"
import IconSearch from "@/components/icons/IconSearch.astro"
import JobOfferCard from "@/components/jobs/JobOfferCard.astro"
import ApiDownBanner from "@/components/ApiDownBanner.astro"
import Pagination from "@/components/Pagination.astro"
import {
  fetchJobOffersPaginated,
  JOB_TYPES,
  JOB_FIELDS,
  WORK_MODES,
  type JobType,
  type JobField,
  type WorkMode,
} from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const PAGE_SIZE = 12

const rawType = Astro.url.searchParams.get("type") ?? "all"
const rawField = Astro.url.searchParams.get("field") ?? "all"
const rawWorkMode = Astro.url.searchParams.get("work_mode") ?? "all"
const search = Astro.url.searchParams.get("search") ?? ""
const rawPage = parseInt(Astro.url.searchParams.get("page") ?? "1", 10)

const type = (JOB_TYPES as readonly string[]).includes(rawType) ? rawType : "all"
const field = (JOB_FIELDS as readonly string[]).includes(rawField) ? rawField : "all"
const workMode = (WORK_MODES as readonly string[]).includes(rawWorkMode) ? rawWorkMode : "all"
const currentPage = isNaN(rawPage) || rawPage < 1 ? 1 : rawPage

const hasActiveFilter = type !== "all" || field !== "all" || workMode !== "all" || search !== ""

const { data, apiDown } = await fetchJobOffersPaginated({
  type,
  field,
  workMode,
  search,
  page: currentPage,
  pageSize: PAGE_SIZE,
})
const { jobs, total, page: actualPage, pageCount } = data

if (!apiDown && jobs.length === 0 && total > 0) {
  const redirectParams = new URLSearchParams(Astro.url.searchParams)
  redirectParams.delete("page")
  const qs = redirectParams.toString()
  return Astro.redirect(qs ? `?${qs}` : Astro.url.pathname)
}

const isLoggedIn = !!Astro.locals.user
---

<PageLayout description={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
  <PageHeader color="success" subtitle={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
    <IconBriefcase class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/jobs">
            {t.auth.myJobOffers}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/job/new">{t.jobs.postJob}</a>
    </div>
  </PageHeader>

  {apiDown && <ApiDownBanner />}

  <form id="jobs-filter-form" method="get">
    <details
      class="group mb-2 rounded-xl border border-base-300"
      open={hasActiveFilter || undefined}
    >
      <summary class="flex cursor-pointer list-none items-center justify-between p-3">
        <div class="flex items-center gap-2">
          <IconSliders class="h-4 w-4 text-base-content/40" />
          <span class="text-sm font-medium">{t.jobs.filterHeading}</span>
        </div>
        <IconChevronDown
          class="h-4 w-4 text-base-content/40 transition-transform group-open:rotate-180"
        />
      </summary>

      <div class="px-5 pb-3">
        <div class="relative mb-1">
          <IconSearch
            class="pointer-events-none absolute left-3 top-1/2 z-1 h-4 w-4 -translate-y-1/2 text-base-content/40"
          />
          <input
            class="input input-bordered w-full pl-9"
            id="filter-search"
            name="search"
            placeholder={t.jobs.filterSearch}
            type="search"
            value={search}
          />
        </div>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-base-content/40" for="filter-type">
              {t.jobs.filterType}
            </label>
            <select class="select select-bordered w-full" id="filter-type" name="type">
              <option selected={type === "all"} value="all">{t.jobs.filterAll}</option>
              {
                JOB_TYPES.map((jt: JobType) => (
                  <option selected={type === jt} value={jt}>
                    {t.jobs.jobTypes[jt]}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-base-content/40" for="filter-field">
              {t.jobs.filterField}
            </label>
            <select class="select select-bordered w-full" id="filter-field" name="field">
              <option selected={field === "all"} value="all">{t.jobs.filterAll}</option>
              {
                JOB_FIELDS.map((jf: JobField) => (
                  <option selected={field === jf} value={jf}>
                    {t.jobs.jobFields[jf]}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-base-content/40" for="filter-work-mode">
              {t.jobs.fieldWorkMode}
            </label>
            <select class="select select-bordered w-full" id="filter-work-mode" name="work_mode">
              <option selected={workMode === "all"} value="all">{t.jobs.filterAll}</option>
              {
                WORK_MODES.map((wm: WorkMode) => (
                  <option selected={workMode === wm} value={wm}>
                    {t.jobs.workModes[wm]}
                  </option>
                ))
              }
            </select>
          </div>
        </div>
      </div>
    </details>
  </form>

  <div class="mb-4 flex items-center justify-between">
    <p aria-live="polite" class="text-sm text-base-content/40">
      <span class="font-medium text-base-content">{total}</span>
      {" "}{total === 1 ? t.jobs.resultSingular : t.jobs.resultPlural}
    </p>
    {
      hasActiveFilter && (
        <a class="btn btn-ghost btn-xs" href={Astro.url.pathname}>
          {t.jobs.clearFilters}
        </a>
      )
    }
  </div>

  {
    !apiDown &&
      (jobs.length === 0 ? (
        <div class="py-4 text-center">
          <IconSearch class="mx-auto mb-4 h-10 w-10 text-base-content/70" />
          <p class="mb-4 text-base-content/70">
            {hasActiveFilter ? t.jobs.noJobsFiltered : t.jobs.noJobs}
          </p>
          {hasActiveFilter && (
            <a class="btn btn-outline btn-sm" href={Astro.url.pathname}>
              {t.jobs.clearFilters}
            </a>
          )}
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {jobs.map((job) => (
            <JobOfferCard job={job} />
          ))}
        </div>
      ))
  }

  <Pagination
    nextLabel={t.jobs.paginationNext}
    page={actualPage}
    pageCount={pageCount}
    prevLabel={t.jobs.paginationPrev}
  />
</PageLayout>

<script>
  const form = document.getElementById("jobs-filter-form") as HTMLFormElement | null
  if (!form) {
    console.error("jobs-filter-form not found")
  } else {
    form.addEventListener("submit", (e) => {
      e.preventDefault()
      const data = new FormData(form)
      const params = new URLSearchParams()
      for (const [key, value] of data) {
        if (value !== "all" && value !== "") params.set(key, value as string)
      }
      const qs = params.toString()
      window.location.href = qs ? `?${qs}` : window.location.pathname
    })

    form.querySelectorAll<HTMLSelectElement>("select").forEach((sel) => {
      sel.addEventListener("change", () => form.requestSubmit())
    })

    let searchTimer: ReturnType<typeof setTimeout>
    const searchEl = form.querySelector<HTMLInputElement>("input[name='search']")
    searchEl?.addEventListener("input", () => {
      clearTimeout(searchTimer)
      searchTimer = setTimeout(() => form.requestSubmit(), 300)
    })
  }
</script>
