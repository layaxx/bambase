---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconBriefcase from "@/components/icons/IconBriefcase.astro"
import IconSliders from "@/components/icons/IconSliders.astro"
import IconChevronDown from "@/components/icons/IconChevronDown.astro"
import IconSearch from "@/components/icons/IconSearch.astro"
import JobOfferCard from "@/components/jobs/JobOfferCard.astro"
import {
  fetchJobOffers,
  JOB_TYPES,
  JOB_FIELDS,
  WORK_MODES,
  type JobType,
  type JobField,
  type WorkMode,
} from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const jobs = await fetchJobOffers()
const isLoggedIn = !!Astro.cookies.get("auth_token")?.value
---

<PageLayout>
  <PageHeader color="success" subtitle={t.jobs.pageSubtitle} title={t.jobs.pageTitle}>
    <IconBriefcase class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/jobs">
            {t.auth.myJobOffers}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/job/new">{t.jobs.postJob}</a>
    </div>
  </PageHeader>

  <details class="group mb-2 rounded-xl border border-base-300" id="filter-panel">
    <summary class="flex cursor-pointer list-none items-center justify-between p-3">
      <div class="flex items-center gap-2">
        <IconSliders class="h-4 w-4 text-base-content/40" />
        <span class="text-sm font-medium">{t.jobs.filterHeading}</span>
      </div>
      <IconChevronDown
        class="h-4 w-4 text-base-content/40 transition-transform group-open:rotate-180"
      />
    </summary>

    <div class="px-5 pb-3">
      <div class="relative mb-1">
        <IconSearch
          class="pointer-events-none absolute left-3 top-1/2 z-1 h-4 w-4 -translate-y-1/2 text-base-content/40"
        />
        <input
          class="input input-bordered w-full pl-9"
          id="filter-search"
          placeholder={t.jobs.filterSearch}
          type="search"
        />
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-medium text-base-content/40" for="filter-type">
            {t.jobs.filterType}
          </label>
          <select class="select select-bordered w-full" id="filter-type">
            <option value="all">{t.jobs.filterAll}</option>
            {
              JOB_TYPES.map((type: JobType) => (
                <option value={type}>{t.jobs.jobTypes[type]}</option>
              ))
            }
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-medium text-base-content/40" for="filter-field">
            {t.jobs.filterField}
          </label>
          <select class="select select-bordered w-full" id="filter-field">
            <option value="all">{t.jobs.filterAll}</option>
            {
              JOB_FIELDS.map((field: JobField) => (
                <option value={field}>{t.jobs.jobFields[field]}</option>
              ))
            }
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-medium text-base-content/40" for="filter-work-mode">
            {t.jobs.fieldWorkMode}
          </label>
          <select class="select select-bordered w-full" id="filter-work-mode">
            <option value="all">{t.jobs.filterAll}</option>
            {
              WORK_MODES.map((mode: WorkMode) => (
                <option value={mode}>{t.jobs.workModes[mode]}</option>
              ))
            }
          </select>
        </div>
      </div>
    </div>
  </details>

  <div class="mb-4 flex items-center justify-between">
    <p class="text-sm text-base-content/40">
      <span class="font-medium text-base-content" id="result-count">{jobs.length}</span>
      {t.jobs.resultOf}
      <span class="font-medium text-base-content">{jobs.length}</span>
      {t.jobs.resultPlural}
    </p>
  </div>
  {
    jobs.length === 0 ? (
      <p class="text-base-content/70">{t.jobs.noJobs}</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="jobs-list">
        {jobs.map((job) => (
          <div
            data-field={job.field}
            data-search={`${job.title} ${job.company}`.toLowerCase()}
            data-type={job.job_type}
            data-work-mode={job.work_mode}
          >
            <JobOfferCard job={job} />
          </div>
        ))}
      </div>
    )
  }
  <div class="hidden py-4 text-center" id="no-jobs-msg">
    <IconSearch class="mx-auto mb-4 h-10 w-10 text-base-content/70" />
    <p class="mb-4 text-base-content/70">{t.jobs.noJobsFiltered}</p>
    <button class="btn btn-outline btn-sm" id="clear-filters-btn">{t.jobs.clearFilters}</button>
  </div>
</PageLayout>

<script>
  import { getParam, setParam } from "@/utils/url-params"

  const typeEl = document.getElementById("filter-type") as HTMLSelectElement | null
  const fieldEl = document.getElementById("filter-field") as HTMLSelectElement | null
  const workModeEl = document.getElementById("filter-work-mode") as HTMLSelectElement | null
  const searchEl = document.getElementById("filter-search") as HTMLInputElement | null
  const noJobsMsgEl = document.getElementById("no-jobs-msg")
  const jobsListEl = document.getElementById("jobs-list")
  const resultCountEl = document.getElementById("result-count")

  function applyFilters() {
    const type = typeEl?.value ?? "all"
    const field = fieldEl?.value ?? "all"
    const workMode = workModeEl?.value ?? "all"
    const search = (searchEl?.value ?? "").toLowerCase().trim()

    let visibleCount = 0
    document.querySelectorAll<HTMLElement>("[data-type]").forEach((card) => {
      const match =
        (type === "all" || card.dataset.type === type) &&
        (field === "all" || card.dataset.field === field) &&
        (workMode === "all" || card.dataset.workMode === workMode) &&
        (!search || (card.dataset.search ?? "").includes(search))
      card.style.display = match ? "" : "none"
      if (match) visibleCount++
    })

    const anyVisible = visibleCount > 0
    noJobsMsgEl?.classList.toggle("hidden", anyVisible)
    jobsListEl?.classList.toggle("hidden", !anyVisible)

    if (resultCountEl) {
      resultCountEl.textContent = String(visibleCount)
    }
  }

  if (typeEl) typeEl.value = getParam("type", "all")
  if (fieldEl) fieldEl.value = getParam("field", "all")
  if (workModeEl) workModeEl.value = getParam("work_mode", "all")
  if (searchEl) searchEl.value = getParam("search", "")

  const filterPanel = document.getElementById("filter-panel") as HTMLDetailsElement | null
  const hasActiveFilters =
    getParam("type", "all") !== "all" ||
    getParam("field", "all") !== "all" ||
    getParam("work_mode", "all") !== "all" ||
    getParam("search", "") !== ""
  if (filterPanel && hasActiveFilters) filterPanel.open = true

  typeEl?.addEventListener("change", () => {
    setParam("type", typeEl.value)
    applyFilters()
  })
  fieldEl?.addEventListener("change", () => {
    setParam("field", fieldEl.value)
    applyFilters()
  })
  workModeEl?.addEventListener("change", () => {
    setParam("work_mode", workModeEl.value)
    applyFilters()
  })

  let searchTimeout: ReturnType<typeof setTimeout>
  searchEl?.addEventListener("input", () => {
    clearTimeout(searchTimeout)
    searchTimeout = setTimeout(() => {
      setParam("search", searchEl.value)
      applyFilters()
    }, 300)
  })

  document.getElementById("clear-filters-btn")?.addEventListener("click", () => {
    if (typeEl) typeEl.value = "all"
    if (fieldEl) fieldEl.value = "all"
    if (workModeEl) workModeEl.value = "all"
    if (searchEl) searchEl.value = ""
    setParam("type", "all")
    setParam("field", "all")
    setParam("work_mode", "all")
    setParam("search", "")
    applyFilters()
  })

  applyFilters()
</script>
