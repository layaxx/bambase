---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import Layout from "../layouts/Layout.astro"
import { fetchJobOffers } from "../utils/api"
import { useTranslations } from "../i18n/translations"

const t = useTranslations(Astro.locals.locale)

const jobs = await fetchJobOffers()
---

<Layout>
  <Header />

  <main class="page-main">
    <section class="mb-10">
      <div class="mb-2 flex items-center gap-2 text-base-content/60">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
          <rect width="20" height="14" x="2" y="6" rx="2"></rect>
        </svg>
        <span class="text-sm font-medium">Bamberg</span>
      </div>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <h1 class="mb-2 text-3xl font-bold tracking-tight sm:text-4xl">{t.jobs.pageTitle}</h1>
          <p class="max-w-2xl text-lg text-base-content/60">{t.jobs.pageSubtitle}</p>
        </div>
        <a href="/job/new" class="btn btn-primary btn-sm">
          {t.jobs.postJob}
        </a>
      </div>
    </section>

    {
      jobs.length === 0 ? (
        <p class="text-base-content/60">{t.jobs.noJobs}</p>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {jobs.map((job) => (
            <a
              href={`/job/${job.uuid}`}
              class="group flex flex-col rounded-xl border border-base-300 bg-base-100 p-4 transition-all hover:shadow-md no-underline">
              <h2 class="mb-1 font-semibold leading-tight text-base-content group-hover:text-primary">
                {job.title}
              </h2>
              <div class="mb-2 flex items-center gap-1.5 text-sm text-base-content/60">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3.5 w-3.5 shrink-0"
                  aria-hidden="true">
                  <path d="M10 12h4" />
                  <path d="M10 8h4" />
                  <path d="M14 21v-3a2 2 0 0 0-4 0v3" />
                  <path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2" />
                  <path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16" />
                </svg>
                <span class="truncate">{job.company}</span>
              </div>
              <p class="mb-3 line-clamp-2 text-sm text-base-content/60">{job.description}</p>
              <div class="mt-auto flex items-center justify-between gap-2 text-sm text-base-content/60">
                <div class="flex items-center gap-1.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-3.5 w-3.5 shrink-0"
                    aria-hidden="true">
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  <span class="truncate">{job.location}</span>
                </div>
                <span class="shrink-0">{t.jobs.workingHours(job.working_hours)}</span>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
</style>
