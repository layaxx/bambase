---
import { actions } from "astro:actions"
import AppLayout from "@/layouts/AppLayout.astro"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const result = Astro.getActionResult(actions.auth.login)
if (result?.data?.success) {
  return Astro.redirect(result.data.redirect || "/")
}

const loggedInButNotConfirmed = result?.data?.notConfirmed === true
const prefillEmail = result?.data?.email || ""

let error: string | null = null
if (result?.error?.message) {
  error = result.error.message
} else if (result?.data?.success === false && !loggedInButNotConfirmed) {
  error = t.auth.validation.loginFailed
}

const emailConfirmed = Astro.url.searchParams.get("confirmed") === "true"
---

<AppLayout title={t.auth.loginTitle}>
  <main class="flex justify-center px-4 py-12 grow" id="main-content">
    <div class="w-full max-w-md">
      <h1 class="text-2xl font-extrabold mb-2">{t.auth.loginTitle}</h1>
      <p class="text-base-content/70 text-sm mb-6">
        {t.auth.noAccount}
        <a class="link link-primary" href="/register">{t.auth.registerLink}</a>
      </p>

      {
        loggedInButNotConfirmed && (
          <div class="alert alert-warning mb-4">
            <div>
              <h3 class="font-bold">{t.auth.emailNotConfirmed}</h3>
              <a
                class="link"
                href={`/resend-confirmation${prefillEmail ? `?email=${encodeURIComponent(prefillEmail)}` : ""}`}
              >
                {t.auth.resendConfirmationLink}
              </a>
            </div>
          </div>
        )
      }

      {
        emailConfirmed && (
          <div class="alert alert-success mb-4">
            <div>
              <h3 class="font-bold">{t.auth.emailConfirmed}</h3>
              <p>{t.auth.emailConfirmedYouCanLogin}</p>
            </div>
          </div>
        )
      }

      {
        error && (
          <div class="alert alert-error mb-4">
            <span>{error}</span>
          </div>
        )
      }

      <form action={actions.auth.login} class="flex flex-col" method="POST">
        <input
          name="redirect"
          type="hidden"
          value={Astro.url.searchParams.get("redirect") || "/"}
        />
        <fieldset class="fieldset">
          <legend class="fieldset-legend">{t.auth.emailLabel}</legend>
          <input
            autocomplete="email"
            class="input w-full"
            name="identifier"
            placeholder={t.auth.emailPlaceholder}
            required
            type="email"
            value={prefillEmail}
          />
        </fieldset>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">{t.auth.passwordLabel}</legend>
          <input
            autocomplete="current-password"
            class="input w-full"
            name="password"
            placeholder={t.auth.passwordPlaceholder}
            required
            type="password"
          />
        </fieldset>

        <button class="btn btn-primary mt-6" type="submit">{t.auth.loginBtn}</button>
      </form>
    </div>
  </main>
</AppLayout>
