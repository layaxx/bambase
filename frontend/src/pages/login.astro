---
import { actions } from "astro:actions"
import AppLayout from "@/layouts/AppLayout.astro"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const result = Astro.getActionResult(actions.auth.login)
if (result?.data?.success) {
  return Astro.redirect(result.data.redirect || "/")
}

const error =
  result?.data?.success === false ? t.auth.validation.loginFailed : result?.error?.message || null
---

<AppLayout>
  <main class="flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <h1 class="text-2xl font-extrabold mb-2">{t.auth.loginTitle}</h1>
      <p class="text-base-content/60 text-sm mb-6">
        {t.auth.noAccount}
        <a class="link link-primary" href="/register">{t.auth.registerLink}</a>
      </p>

      {
        error && (
          <div class="alert alert-error mb-4">
            <span>{error}</span>
          </div>
        )
      }

      <form action={actions.auth.login} class="flex flex-col" method="POST">
        <input
          name="redirect"
          type="hidden"
          value={Astro.url.searchParams.get("redirect") || "/"}
        />
        <fieldset class="fieldset">
          <legend class="fieldset-legend">{t.auth.emailLabel}</legend>
          <input
            autocomplete="email"
            class="input w-full"
            name="identifier"
            placeholder={t.auth.emailPlaceholder}
            required
            type="email"
            value={result?.data?.username || ""}
          />
        </fieldset>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">{t.auth.passwordLabel}</legend>
          <input
            autocomplete="current-password"
            class="input w-full"
            name="password"
            placeholder={t.auth.passwordPlaceholder}
            required
            type="password"
          />
        </fieldset>

        <button class="btn btn-primary mt-6" type="submit">{t.auth.loginBtn}</button>
      </form>
    </div>
  </main>
</AppLayout>
