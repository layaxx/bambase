---
import { actions } from "astro:actions"
import AppLayout from "@/layouts/AppLayout.astro"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const code = Astro.url.searchParams.get("code") || ""
const result = Astro.getActionResult(actions.auth.resetPassword)

const succeeded = result?.data?.success === true
const missingCode = !code && !succeeded
const error = result?.error ? result.error.message || t.auth.validation.resetFailed : null
---

<AppLayout title={t.auth.resetPasswordTitle}>
  <main class="flex justify-center px-4 py-12 grow" id="main-content">
    <div class="w-full max-w-md">
      <h1 class="text-2xl font-extrabold mb-2">{t.auth.resetPasswordTitle}</h1>

      {
        succeeded && (
          <>
            <div class="alert alert-success mb-4">
              <span>{t.auth.resetPasswordSuccess}</span>
            </div>
            <p class="text-base-content/70 text-sm mt-4">
              <a class="link link-primary" href="/login">
                {t.auth.loginLink}
              </a>
            </p>
          </>
        )
      }

      {
        missingCode && (
          <>
            <div class="alert alert-error mb-4">
              <span>{t.auth.resetPasswordInvalidCode}</span>
            </div>
            <p class="text-base-content/70 text-sm mt-4">
              <a class="link link-primary" href="/forgot-password">
                {t.auth.forgotPasswordLink}
              </a>
            </p>
          </>
        )
      }

      {
        !succeeded && !missingCode && (
          <>
            <p class="text-base-content/70 text-sm mb-6">{t.auth.resetPasswordInstruction}</p>

            {error && (
              <div class="alert alert-error mb-4">
                <span>{error}</span>
              </div>
            )}

            <form action={actions.auth.resetPassword} class="flex flex-col" method="POST">
              <input name="code" type="hidden" value={code} />

              <fieldset class="fieldset">
                <legend class="fieldset-legend">{t.auth.resetPasswordNewLabel}</legend>
                <input
                  autocomplete="new-password"
                  class="input w-full"
                  minlength="10"
                  name="password"
                  placeholder={t.auth.passwordPlaceholder}
                  required
                  type="password"
                />
                <p class="fieldset-label">{t.auth.passwordMinHint}</p>
              </fieldset>

              <fieldset class="fieldset">
                <legend class="fieldset-legend">{t.auth.resetPasswordConfirmLabel}</legend>
                <input
                  autocomplete="new-password"
                  class="input w-full"
                  name="passwordConfirm"
                  placeholder={t.auth.confirmPasswordPlaceholder}
                  required
                  type="password"
                />
              </fieldset>

              <button class="btn btn-primary mt-6" type="submit">
                {t.auth.resetPasswordBtn}
              </button>
            </form>
          </>
        )
      }
    </div>
  </main>
</AppLayout>
