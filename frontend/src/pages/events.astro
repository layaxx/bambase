---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconCalendar from "@/components/icons/IconCalendar.astro"
import EventCard from "@/components/EventCard.astro"
import { fetchEvents } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)
const dateLocale = t.mensa.dateLocale

const events = await fetchEvents()
const isLoggedIn = !!Astro.cookies.get("auth_token")?.value

const grouped = Map.groupBy(events, (e) =>
  new Date(e.start).toLocaleDateString(dateLocale, {
    weekday: "long",
    day: "numeric",
    month: "long",
  })
)
---

<PageLayout>
  <PageHeader label="Bamberg" subtitle={t.events.pageSubtitle} title={t.events.pageTitle}>
    <IconCalendar class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/events">
            {t.auth.myEvents}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/event/new">{t.events.submitEvent}</a>
    </div>
  </PageHeader>

  {
    events.length === 0 ? (
      <p class="text-base-content/60">{t.events.noEvents}</p>
    ) : (
      <div class="space-y-10">
        {[...grouped.entries()].map(([day, dayEvents]) => (
          <div>
            <h2 class="mb-4 text-lg font-semibold capitalize">{day}</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {dayEvents.map((event) => (
                <EventCard event={event} />
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }
</PageLayout>
