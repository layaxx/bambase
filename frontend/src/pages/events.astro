---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconCalendar from "@/components/icons/IconCalendar.astro"
import EventCard from "@/components/EventCard.astro"
import { fetchEvents, EVENT_CATEGORIES } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)
const dateLocale = t.mensa.dateLocale

const events = await fetchEvents()
const isLoggedIn = !!Astro.cookies.get("auth_token")?.value

const grouped = Map.groupBy(events, (e) =>
  new Date(e.start).toLocaleDateString(dateLocale, {
    weekday: "long",
    day: "numeric",
    month: "long",
  })
)

const dateFilters = [
  { key: "upcoming", label: t.events.filterDateUpcoming },
  { key: "week", label: t.events.filterDateWeek },
  { key: "month", label: t.events.filterDateMonth },
] as const
---

<PageLayout title={t.events.pageTitle}>
  <PageHeader color="primary" subtitle={t.events.pageSubtitle} title={t.events.pageTitle}>
    <IconCalendar class="h-5 w-5" slot="icon" />
    <div class="flex items-center gap-2" slot="action">
      {
        isLoggedIn && (
          <a class="btn btn-outline btn-sm" href="/account/events">
            {t.auth.myEvents}
          </a>
        )
      }
      <a class="btn btn-primary btn-sm" href="/event/new">{t.events.submitEvent}</a>
    </div>
  </PageHeader>

  <div class="mb-2 flex flex-col gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm text-base-content/40">{t.events.filterCategory}:</span>
      <button class="btn btn-outline btn-sm" data-cat-filter="all">
        {t.events.filterAll}
      </button>
      {
        EVENT_CATEGORIES.map((cat) => (
          <button class="btn btn-outline btn-sm" data-cat-filter={cat}>
            {t.events.categories[cat]}
          </button>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <label class="text-sm text-base-content/40" for="event-date-filter">
        {t.events.filterDate}:
      </label>
      <select class="select select-bordered select-xs" id="event-date-filter">
        {dateFilters.map(({ key, label }) => <option value={key}>{label}</option>)}
      </select>
    </div>
  </div>

  <p
    class="mb-4 text-sm text-base-content/40"
    data-plural={t.events.resultPlural}
    data-singular={t.events.resultSingular}
    id="result-count"
  >
  </p>

  {
    events.length === 0 ? (
      <p class="text-base-content/70">{t.events.noEvents}</p>
    ) : (
      <div class="space-y-10" id="events-list">
        {[...grouped.entries()].map(([day, dayEvents]) => (
          <div data-day-section>
            <h2 class="mb-4 text-lg font-semibold capitalize">{day}</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {dayEvents.map((event) => (
                <div data-category={event.category} data-start={event.start}>
                  <EventCard event={event} />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }
  <div class="hidden" id="no-events-msg">
    <p class="text-base-content/70">{t.events.noEventsFiltered}</p>
    <button class="btn btn-ghost btn-sm mt-2" id="clear-filters-btn">{t.events.clearFilters}</button
    >
  </div>
</PageLayout>

<script>
  import { getParam, setParam } from "@/utils/url-params"

  function applyFilters() {
    const cat = getParam("category", "all")
    const date = getParam("date", "upcoming")
    const now = Date.now()
    const cutoff =
      date === "week" ? now + 7 * 86400_000 : date === "month" ? now + 31 * 86400_000 : Infinity

    let visibleCount = 0
    document.querySelectorAll<HTMLElement>("[data-category]").forEach((card) => {
      const catMatch = cat === "all" || card.dataset.category === cat
      const startMs = new Date(card.dataset.start!).getTime()
      const dateMatch = startMs <= cutoff
      const visible = catMatch && dateMatch
      card.style.display = visible ? "" : "none"
      if (visible) visibleCount++
    })

    // Each day section is hidden when all its cards are filtered out
    let anyVisible = false
    document.querySelectorAll<HTMLElement>("[data-day-section]").forEach((section) => {
      const sectionVisible = [...section.querySelectorAll<HTMLElement>("[data-category]")].some(
        (c) => c.style.display !== "none"
      )
      section.style.display = sectionVisible ? "" : "none"
      if (sectionVisible) anyVisible = true
    })

    document.getElementById("no-events-msg")?.classList.toggle("hidden", anyVisible)
    document.getElementById("events-list")?.classList.toggle("hidden", !anyVisible)

    const countEl = document.getElementById("result-count")
    if (countEl) {
      const singular = countEl.dataset.singular!
      const plural = countEl.dataset.plural!
      countEl.textContent = `${visibleCount} ${visibleCount === 1 ? singular : plural}`
    }

    document.querySelectorAll<HTMLElement>("[data-cat-filter]").forEach((btn) => {
      const active = btn.dataset.catFilter === cat
      btn.classList.toggle("btn-primary", active)
      btn.classList.toggle("btn-outline", !active)
    })

    const sel = document.getElementById("event-date-filter") as HTMLSelectElement | null
    if (sel) sel.value = date
  }

  document.querySelectorAll<HTMLElement>("[data-cat-filter]").forEach((btn) => {
    btn.addEventListener("click", () => {
      setParam("category", btn.dataset.catFilter!)
      applyFilters()
    })
  })

  document.getElementById("event-date-filter")?.addEventListener("change", (e) => {
    setParam("date", (e.target as HTMLSelectElement).value)
    applyFilters()
  })

  document.getElementById("clear-filters-btn")?.addEventListener("click", () => {
    setParam("category", "all")
    setParam("date", "upcoming")
    applyFilters()
  })

  applyFilters()
</script>
