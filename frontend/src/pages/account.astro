---
import PageLayout from "@/layouts/PageLayout.astro"
import { useTranslations } from "@/i18n/translations"
import { STRAPI_URL } from "astro:env/client"
import { deleteAuthCookies } from "@/utils/auth-cookies"

const t = useTranslations(Astro.locals.locale)

const user = Astro.locals.user
const token = Astro.locals.token
if (!user || !token) return Astro.redirect("/login?redirect=/account")

const profileRes = await fetch(`${STRAPI_URL}/api/users/me`, {
  headers: { Authorization: `Bearer ${token}` },
  signal: AbortSignal.timeout(3000),
})
if (!profileRes.ok) {
  if (profileRes.status === 401 || profileRes.status === 403) {
    deleteAuthCookies(Astro.cookies)

    console.warn("Unauthorized access to profile, logging user out")
  } else {
    throw new Error(`Failed to fetch profile: ${profileRes.status} ${profileRes.statusText}`)
  }
  return Astro.redirect("/login?redirect=/account")
}
const profile: { email: string; createdAt: string } = await profileRes.json()
---

<PageLayout title={t.auth.accountTitle}>
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl mb-8">{t.auth.accountTitle}</h1>

  <div class="card bg-base-100 border border-base-300">
    <div class="card-body gap-4">
      <div class="flex flex-col gap-1">
        <span class="text-xs text-base-content/40 uppercase tracking-wide"
          >{t.auth.emailFieldLabel}</span
        >
        <span class="font-medium">{profile.email}</span>
      </div>
      <div class="divider my-0"></div>
      <div class="flex flex-col gap-1">
        <span class="text-xs text-base-content/40 uppercase tracking-wide"
          >{t.auth.memberSince}</span
        >
        <span class="font-medium">
          {
            new Date(profile.createdAt).toLocaleDateString(t.auth.dateLocale, {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </span>
      </div>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <a class="btn btn-outline btn-sm" href="/account/jobs">{t.auth.myJobOffers}</a>
    <a class="btn btn-outline btn-sm" href="/account/events">{t.auth.myEvents}</a>
  </div>

  <div class="mt-4">
    <a class="btn btn-ghost btn-sm" href="/logout">{t.auth.logout}</a>
  </div>
</PageLayout>
