---
import { deleteAuthCookies } from "@/utils/auth-cookies"
import { STRAPI_URL } from "astro:env/client"

const jwt = Astro.locals.token
if (jwt) {
  try {
    await fetch(`${STRAPI_URL}/api/auth/logout`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${jwt}`,
      },
      signal: AbortSignal.timeout(3000),
    })
  } catch {
    // Logout is best-effort — always clear cookies regardless
  }
}

deleteAuthCookies(Astro.cookies)
return Astro.redirect("/")
---
