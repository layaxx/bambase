---
import { actions } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import { fetchMyEvents } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const { data: user, error } = await Astro.callAction(actions.auth.getMe, {})

if (error) {
  Astro.cookies.delete("auth_token", { path: "/" })
  Astro.cookies.delete("auth_user", { path: "/" })
  return Astro.redirect("/login")
}

const token = Astro.cookies.get("auth_token")!.value
const events = await fetchMyEvents(token, user.id)
const dateLocale = t.mensa.dateLocale

function formatDateTime(iso: string) {
  return new Date(iso).toLocaleString(dateLocale, {
    weekday: "short",
    day: "numeric",
    month: "short",
    hour: "2-digit",
    minute: "2-digit",
  })
}
---

<PageLayout>
  <div class="mb-6">
    <a class="btn btn-ghost btn-sm gap-1 pl-0" href="/account">
      <IconArrowLeft class="h-4 w-4" />
      {t.nav.myAccount}
    </a>
  </div>
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl mb-6">{t.auth.myEvents}</h1>

  {
    events.length === 0 ? (
      <p class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/70">
        {t.auth.noMyEvents}
      </p>
    ) : (
      <div class="flex flex-col gap-3">
        {events.map((event) => (
          <a
            class="group flex flex-col gap-1 rounded-xl border border-base-300 bg-base-100 p-4 no-underline transition-all hover:shadow-md"
            href={`/event/${event.slug}`}
          >
            <h2 class="font-semibold leading-snug text-base-content group-hover:text-primary">
              {event.title}
            </h2>
            <p class="text-sm text-base-content/70">
              {formatDateTime(event.start)} – {formatDateTime(event.end)}
            </p>
            <p class="text-sm text-base-content/70">{event.organizer}</p>
            <p class="line-clamp-2 text-sm text-base-content/40">{event.description}</p>
          </a>
        ))}
      </div>
    )
  }

  <div class="mt-6">
    <a class="btn btn-primary btn-sm" href="/event/new">{t.events.submitEvent}</a>
  </div>
</PageLayout>
