---
import { actions } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import { fetchMyJobOffers } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const { data: user, error } = await Astro.callAction(actions.auth.getMe, {})

if (error) {
  Astro.cookies.delete("auth_token", { path: "/" })
  Astro.cookies.delete("auth_user", { path: "/" })
  return Astro.redirect("/login")
}

const token = Astro.cookies.get("auth_token")!.value
const jobs = await fetchMyJobOffers(token, user.id)

const statusLabel: Record<string, string> = {
  submitted: t.auth.statusSubmitted,
  published: t.auth.statusPublished,
  expired: t.auth.statusExpired,
  rejected: t.auth.statusRejected,
  archived: t.auth.statusArchived,
}

const statusClass: Record<string, string> = {
  submitted: "badge-warning",
  published: "badge-success",
  expired: "badge-neutral",
  rejected: "badge-error",
  archived: "badge-info",
}
---

<PageLayout>
  <div class="mb-6 flex items-center gap-3">
    <a aria-label="Back" class="btn btn-ghost btn-sm btn-square" href="/account">
      <IconArrowLeft class="h-4 w-4" />
    </a>
    <h1 class="text-2xl font-extrabold">{t.auth.myJobOffers}</h1>
  </div>

  {
    jobs.length === 0 ? (
      <p class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/60">
        {t.auth.noMyJobOffers}
      </p>
    ) : (
      <div class="flex flex-col gap-3">
        {jobs.map((job) => (
          <a
            class="group flex flex-col gap-1 rounded-xl border border-base-300 bg-base-100 p-4 no-underline transition-all hover:shadow-md"
            href={`/job/${job.uuid}`}
          >
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-semibold leading-snug text-base-content group-hover:text-primary">
                {job.title}
              </h2>
              <span
                class:list={[
                  `badge badge-sm shrink-0`,
                  `${statusClass[job.online_status] ?? "badge-neutral"}`,
                ]}
              >
                {statusLabel[job.online_status] ?? job.online_status}
              </span>
            </div>
            <p class="text-sm text-base-content/60">
              {job.company} · {job.location}
            </p>
            <p class="line-clamp-2 text-sm text-base-content/50">{job.description}</p>
          </a>
        ))}
      </div>
    )
  }

  <div class="mt-6">
    <a class="btn btn-primary btn-sm" href="/job/new">{t.jobs.postJob}</a>
  </div>
</PageLayout>
