---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconUtensils from "@/components/icons/IconUtensils.astro"
import MensaDaySection from "@/components/mensa/MensaDaySection.astro"
import MensaWeekendSection from "@/components/mensa/MensaWeekendSection.astro"
import { fetchMensaMeals } from "@/utils/api"
import dayjs from "dayjs"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const today = dayjs()
const days = Array.from({ length: 7 }, (_, i) => today.add(i, "day"))

const mealsByDay = await Promise.all(
  days.map(async (day) => ({
    day,
    meals: await fetchMensaMeals(day),
  }))
)

// Group consecutive Saturday + Sunday into a single weekend entry
type WeekdayEntry = {
  type: "weekday"
  heading: string
  meals: Awaited<ReturnType<typeof fetchMensaMeals>>
}
type WeekendEntry = { type: "weekend"; heading: string }
type DayEntry = WeekdayEntry | WeekendEntry

function formatDate(d: dayjs.Dayjs) {
  return d.toDate().toLocaleDateString(t.mensa.dateLocale, { day: "numeric", month: "long" })
}

const grouped: DayEntry[] = []
let i = 0
while (i < mealsByDay.length) {
  const { day, meals } = mealsByDay[i]
  const dow = day.day()
  const nextDow = i + 1 < mealsByDay.length ? mealsByDay[i + 1].day.day() : -1

  if (dow === 6 && nextDow === 0) {
    const heading = t.mensa.weekendHeading(formatDate(day), formatDate(mealsByDay[i + 1].day))
    grouped.push({ type: "weekend", heading })
    i += 2
  } else if (dow === 0 || dow === 6) {
    grouped.push({ type: "weekend", heading: `${t.mensa.weekdays[dow]}, ${formatDate(day)}` })
    i++
  } else {
    const label = i === 0 ? t.mensa.today : i === 1 ? t.mensa.tomorrow : t.mensa.weekdays[dow]
    grouped.push({ type: "weekday", heading: `${label}, ${formatDate(day)}`, meals })
    i++
  }
}
---

<PageLayout>
  <PageHeader
    label={t.mensa.pageLocations}
    title={t.mensa.pageTitle}
    subtitle={t.mensa.pageSubtitle}
  >
    <IconUtensils slot="icon" class="h-5 w-5" />
  </PageHeader>

  <div class="flex flex-col gap-10">
    {
      grouped.map((entry) =>
        entry.type === "weekend" ? (
          <MensaWeekendSection heading={entry.heading} />
        ) : (
          <MensaDaySection heading={entry.heading} meals={entry.meals} />
        )
      )
    }
  </div>
</PageLayout>
