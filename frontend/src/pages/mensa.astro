---
import PageLayout from "@/layouts/PageLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import IconUtensils from "@/components/icons/IconUtensils.astro"
import MensaDaySection from "@/components/mensa/MensaDaySection.astro"
import MensaWeekendSection from "@/components/mensa/MensaWeekendSection.astro"
import { fetchMensaMeals } from "@/utils/api"
import { groupMealsByDay } from "@/utils/mensa"
import dayjs from "dayjs"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)

const today = dayjs()
const days = Array.from({ length: 7 }, (_, i) => today.add(i, "day"))

const mealsByDay = await Promise.all(
  days.map(async (day) => ({
    day,
    meals: await fetchMensaMeals(day),
  }))
)

const grouped = groupMealsByDay(mealsByDay, {
  today: t.mensa.today,
  tomorrow: t.mensa.tomorrow,
  weekdays: t.mensa.weekdays,
  weekendHeading: t.mensa.weekendHeading,
  dateLocale: t.mensa.dateLocale,
})
---

<PageLayout description={t.mensa.pageSubtitle} title={t.mensa.pageTitle}>
  <PageHeader color="warning" subtitle={t.mensa.pageSubtitle} title={t.mensa.pageTitle}>
    <IconUtensils class="h-5 w-5" slot="icon" />
  </PageHeader>

  <div class="flex flex-col gap-10">
    {
      grouped.map((entry) =>
        entry.type === "weekend" ? (
          <MensaWeekendSection heading={entry.heading} id={entry.id} />
        ) : (
          <MensaDaySection heading={entry.heading} id={entry.id} meals={entry.meals} />
        )
      )
    }
  </div>
</PageLayout>
