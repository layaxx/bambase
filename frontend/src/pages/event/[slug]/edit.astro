---
import { actions, isInputError } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { fetchEvent } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"

const t = useTranslations(Astro.locals.locale)

const token = Astro.cookies.get("auth_token")?.value
if (!token) return Astro.redirect(`/login?redirect=/event/${Astro.params.slug}/edit`)

const { slug } = Astro.params
const event = slug ? await fetchEvent(slug) : null

if (!event) return Astro.redirect("/events")

// Ownership check
const { data: me, error: meError } = await Astro.callAction(actions.auth.getMe, {})
if (meError || !me || event.owner?.id !== me.id) return Astro.redirect(`/event/${slug}`)

const result = Astro.getActionResult(actions.events.update)
if (result?.data) return Astro.redirect(`/event/${result.data.slug}`)

const inputErrors = isInputError(result?.error) ? result.error.fields : {}
const generalError = result?.error && !isInputError(result.error) ? result.error.message : null

// Format ISO datetime to the value expected by datetime-local inputs
function toLocalInput(iso: string) {
  const d = new Date(iso)
  const pad = (n: number) => String(n).padStart(2, "0")
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`
}
---

<PageLayout>
  <div class="mb-6">
    <a class="btn btn-ghost btn-sm gap-1 pl-0" href={`/event/${slug}`}>
      <IconArrowLeft class="h-4 w-4" />
      {t.events.backToEvents}
    </a>
  </div>

  <section class="mb-8">
    <h1 class="mb-1 text-3xl font-bold tracking-tight sm:text-4xl">{t.events.editTitle}</h1>
  </section>

  {
    generalError && (
      <div class="alert alert-error mb-6" role="alert">
        <span>{generalError}</span>
      </div>
    )
  }

  <form action={actions.events.update} class="flex max-w-2xl flex-col gap-6" method="POST">
    <input name="documentId" type="hidden" value={event.documentId} />

    <div class="flex flex-col gap-4">
      <div class="form-control">
        <label class="label" for="title">
          <span class="label-text font-medium">{t.events.fieldTitle}</span>
        </label>
        <input
          class:list={["input input-bordered w-full", inputErrors.title && "input-error"]}
          id="title"
          name="title"
          required
          type="text"
          value={event.title}
        />
        {inputErrors.title && <p class="mt-1 text-sm text-error">{inputErrors.title[0]}</p>}
      </div>

      <div class="form-control">
        <label class="label" for="organizer">
          <span class="label-text font-medium">{t.events.fieldOrganizer}</span>
        </label>
        <input
          class:list={["input input-bordered w-full", inputErrors.organizer && "input-error"]}
          id="organizer"
          name="organizer"
          required
          type="text"
          value={event.organizer}
        />
        {inputErrors.organizer && <p class="mt-1 text-sm text-error">{inputErrors.organizer[0]}</p>}
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="form-control">
          <label class="label" for="start">
            <span class="label-text font-medium">{t.events.fieldStart}</span>
          </label>
          <input
            class:list={["input input-bordered w-full", inputErrors.start && "input-error"]}
            id="start"
            name="start"
            required
            type="datetime-local"
            value={toLocalInput(event.start)}
          />
          {inputErrors.start && <p class="mt-1 text-sm text-error">{inputErrors.start[0]}</p>}
        </div>

        <div class="form-control">
          <label class="label" for="end">
            <span class="label-text font-medium">{t.events.fieldEnd}</span>
          </label>
          <input
            class:list={["input input-bordered w-full", inputErrors.end && "input-error"]}
            id="end"
            name="end"
            required
            type="datetime-local"
            value={toLocalInput(event.end)}
          />
          {inputErrors.end && <p class="mt-1 text-sm text-error">{inputErrors.end[0]}</p>}
        </div>
      </div>

      <div class="form-control">
        <label class="label" for="category">
          <span class="label-text font-medium">{t.events.fieldCategory}</span>
        </label>
        <select class="select select-bordered w-full" id="category" name="category" required>
          {
            Object.entries(t.events.categories).map(([value, label]) => (
              <option selected={event.category === value} value={value}>
                {label}
              </option>
            ))
          }
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="description">
          <span class="label-text font-medium">{t.events.fieldDescription}</span>
        </label>
        <textarea
          class:list={[
            "textarea textarea-bordered w-full resize-y",
            inputErrors.description && "textarea-error",
          ]}
          id="description"
          name="description"
          required
          rows="6">{event.description}</textarea
        >
        {
          inputErrors.description && (
            <p class="mt-1 text-sm text-error">{inputErrors.description[0]}</p>
          )
        }
      </div>

      <div class="form-control">
        <label class="label" for="external_url">
          <span class="label-text font-medium">
            {t.events.fieldExternalUrl}
            <span class="font-normal text-base-content/50"> {t.events.optionalLabel}</span>
          </span>
        </label>
        <input
          class:list={["input input-bordered w-full", inputErrors.external_url && "input-error"]}
          id="external_url"
          name="external_url"
          type="url"
          value={event.external_url ?? ""}
        />
        {
          inputErrors.external_url && (
            <p class="mt-1 text-sm text-error">{inputErrors.external_url[0]}</p>
          )
        }
      </div>
    </div>

    <div>
      <button class="btn btn-primary" type="submit">
        {t.events.updateEvent}
      </button>
    </div>
  </form>
</PageLayout>
