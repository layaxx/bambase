---
import { actions, isInputError } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { fetchEvent, fetchLocations } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import EventForm from "@/components/events/EventForm.astro"

const t = useTranslations(Astro.locals.locale)

const token = Astro.cookies.get("auth_token")?.value
if (!token) return Astro.redirect(`/login?redirect=/event/${Astro.params.slug}/edit`)

const { slug } = Astro.params
const [event, allLocations] = await Promise.all([
  slug ? fetchEvent(slug) : Promise.resolve(null),
  fetchLocations(),
])

if (!event) return Astro.redirect("/events")

// Ownership check
const { data: me, error: meError } = await Astro.callAction(actions.auth.getMe, {})
if (meError || !me || event.owner?.id !== me.id) return Astro.redirect(`/event/${slug}`)

const result = Astro.getActionResult(actions.events.update)
if (result?.data) return Astro.redirect(`/event/${result.data.slug}`)

const inputErrors = isInputError(result?.error) ? result.error.fields : {}
const generalError = result?.error && !isInputError(result.error) ? result.error.message : null

// Format ISO datetime to the value expected by datetime-local inputs
function toLocalInput(iso: string) {
  const d = new Date(iso)
  const pad = (n: number) => String(n).padStart(2, "0")
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`
}
---

<PageLayout>
  <div class="mb-6">
    <a class="btn btn-ghost btn-sm gap-1 pl-0" href={`/event/${slug}`}>
      <IconArrowLeft class="h-4 w-4" />
      {t.events.backToEvents}
    </a>
  </div>

  <section class="mb-8">
    <h1 class="mb-1 text-3xl font-bold tracking-tight sm:text-4xl">{t.events.editTitle}</h1>
  </section>

  {
    generalError && (
      <div class="alert alert-error mb-6" role="alert">
        <span>{generalError}</span>
      </div>
    )
  }

  <EventForm
    action={actions.events.update}
    allLocations={allLocations}
    documentId={event.documentId}
    initialValues={{
      title: event.title,
      organizer: event.organizer,
      start: toLocalInput(event.start),
      end: toLocalInput(event.end),
      category: event.category,
      description: event.description,
      external_url: event.external_url,
      locationType: event.map_location ? "linked" : event.custom_location ? "custom" : "none",
      map_location_documentId: event.map_location?.documentId,
      custom_location_name: event.custom_location?.name,
      custom_location_address: event.custom_location?.address,
      custom_location_city: event.custom_location?.city,
    }}
    inputErrors={inputErrors}
    submitLabel={t.events.updateEvent}
  />
</PageLayout>
