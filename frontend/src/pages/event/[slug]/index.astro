---
import { actions } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { fetchEvent } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import IconClock from "@/components/icons/IconClock.astro"
import IconExternalLink from "@/components/icons/IconExternalLink.astro"

const t = useTranslations(Astro.locals.locale)
const dateLocale = t.mensa.dateLocale

const { slug } = Astro.params
const event = slug ? await fetchEvent(slug) : null

// Check if logged-in user is the owner
const { data: me } = await Astro.callAction(actions.auth.getMe, {})
const isOwner = me && event?.owner?.id === me.id

// Handle delete result
const deleteResult = Astro.getActionResult(actions.events.delete)
if (deleteResult?.data !== undefined && !deleteResult.error) {
  return Astro.redirect("/account/events")
}

function formatDateTime(iso: string) {
  return new Date(iso).toLocaleString(dateLocale, {
    weekday: "long",
    day: "numeric",
    month: "long",
    hour: "2-digit",
    minute: "2-digit",
  })
}

function formatTime(iso: string) {
  return new Date(iso).toLocaleTimeString(dateLocale, {
    hour: "2-digit",
    minute: "2-digit",
  })
}
---

<PageLayout>
  {
    !event ? (
      <div class="py-20 text-center">
        <h1 class="mb-4 text-3xl font-bold">{t.events.notFound.headline}</h1>
        <p class="text-base-content/60">{t.events.notFound.description}</p>
        <div class="mt-6">
          <a href="/events" class="btn btn-primary">
            {t.events.backToEvents}
          </a>
        </div>
      </div>
    ) : (
      <>
        <div class="mb-6 flex items-center justify-between gap-4">
          <a href="/events" class="btn btn-ghost btn-sm gap-1 pl-0">
            <IconArrowLeft class="h-4 w-4" />
            {t.events.backToEvents}
          </a>
          {isOwner && (
            <div class="flex items-center gap-2">
              <a href="/account/events" class="btn btn-ghost btn-sm">
                {t.auth.myEvents}
              </a>
              <a href={`/event/${event.slug}/edit`} class="btn btn-outline btn-sm">
                {t.events.editEvent}
              </a>
              <form
                method="POST"
                action={actions.events.delete}
                onsubmit={`return confirm('${t.events.deleteConfirm}')`}>
                <input type="hidden" name="documentId" value={event.documentId} />
                <button type="submit" class="btn btn-outline btn-error btn-sm">
                  {t.events.deleteEvent}
                </button>
              </form>
            </div>
          )}
        </div>

        <div class="grid gap-8 lg:grid-cols-3">
          <div class="lg:col-span-2">
            <div class="mb-2 text-sm font-medium text-base-content/60">{event.organizer}</div>
            <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">{event.title}</h1>

            <div class="mb-6 flex flex-wrap gap-4 text-sm text-base-content/60">
              <div class="flex items-center gap-1.5">
                <IconClock class="h-4 w-4 shrink-0" />
                <span>
                  {formatDateTime(event.start)}
                  {" – "}
                  {formatTime(event.end)}
                  {t.events.clock ? ` ${t.events.clock}` : ""}
                </span>
              </div>
            </div>

            <div class="prose prose-sm max-w-none text-base-content/80">
              <p class="whitespace-pre-wrap">{event.description}</p>
            </div>
          </div>

          <aside class="flex flex-col gap-4">
            <div class="rounded-xl border border-base-300 bg-base-100 p-5">
              <dl class="flex flex-col gap-3 text-sm">
                <div>
                  <dt class="text-base-content/60">{t.events.organizer}</dt>
                  <dd class="font-medium">{event.organizer}</dd>
                </div>
                <div>
                  <dt class="mb-1 text-base-content/60">{t.events.until}</dt>
                  <dd class="font-medium">{formatDateTime(event.start)}</dd>
                  <dd class="text-base-content/60">
                    – {formatTime(event.end)}
                    {t.events.clock ? ` ${t.events.clock}` : ""}
                  </dd>
                </div>
              </dl>
            </div>

            {event.external_url && (
              <a
                href={event.external_url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary w-full">
                {t.events.moreInfo}
                <IconExternalLink class="h-4 w-4" />
              </a>
            )}
          </aside>
        </div>
      </>
    )
  }
</PageLayout>
