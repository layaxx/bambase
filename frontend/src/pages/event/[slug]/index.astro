---
import { actions } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { fetchEvent, REPORT_WARNING_THRESHOLD, type Event } from "@/utils/api"
import { useTranslations } from "@/i18n/translations"
import ConfirmModal from "@/components/ConfirmModal.astro"
import ApiDownBanner from "@/components/ApiDownBanner.astro"
import EventDetailPage from "@/components/events/EventDetailPage.astro"

const t = useTranslations(Astro.locals.locale)

const { slug } = Astro.params
const [{ data: event, apiDown }, { data: me }] = await Promise.all([
  slug ? fetchEvent(slug) : Promise.resolve({ data: null as Event | null, apiDown: false }),
  Astro.callAction(actions.auth.getMe, {}),
])
const isOwner = me && event?.owner?.id === me.id

const deleteResult = Astro.getActionResult(actions.events.delete)
if (deleteResult?.data !== undefined && !deleteResult.error) {
  return Astro.redirect("/account/events")
}

const hasReports = (event?.reports?.length ?? 0) >= REPORT_WARNING_THRESHOLD

const reportResult = Astro.getActionResult(actions.reports.submit)
if (reportResult) {
  return Astro.redirect(
    `${Astro.url.pathname}?reported=${reportResult.error ? "error" : "success"}`
  )
}

const hasBeenReported = Astro.url.searchParams.get("reported")

const description = event?.description?.slice(0, 155)
const ogImage = event ? `${Astro.url.origin}/api/og/event/${event.slug}.png` : undefined
---

<PageLayout description={description} ogImage={ogImage} title={event?.title ?? t.events.pageTitle}>
  {
    apiDown ? (
      <ApiDownBanner />
    ) : !event ? (
      <div class="py-20 text-center">
        <h1 class="mb-4 text-3xl font-bold">{t.events.notFound.headline}</h1>
        <p class="text-base-content/70">{t.events.notFound.description}</p>
        <div class="mt-6">
          <a class="btn btn-primary" href="/events">
            {t.events.backToEvents}
          </a>
        </div>
      </div>
    ) : (
      <EventDetailPage
        event={event}
        hasBeenReported={hasBeenReported}
        hasReports={hasReports}
        isOwner={isOwner}
      />
    )
  }
  {
    event && isOwner && (
      <ConfirmModal
        confirmClass="btn btn-error"
        confirmLabel={t.events.deleteEvent}
        formAction={actions.events.delete}
        hiddenInputs={[{ name: "documentId", value: event.documentId }]}
        id="deleteEventModal"
        message={t.events.deleteConfirm}
      />
    )
  }
</PageLayout>
