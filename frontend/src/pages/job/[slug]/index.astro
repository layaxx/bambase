---
import { actions } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { fetchJobOffer, REPORT_WARNING_THRESHOLD } from "@/utils/api"
import { JOB_STATUS_ALERT_CLASS } from "@/utils/job-status"
import { useTranslations } from "@/i18n/translations"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import IconStore from "@/components/icons/IconStore.astro"
import IconMapPin from "@/components/icons/IconMapPin.astro"
import IconClock from "@/components/icons/IconClock.astro"
import IconExternalLink from "@/components/icons/IconExternalLink.astro"
import ReportModal from "@/components/ReportModal.astro"
import JobTypeBadge from "@/components/jobs/JobTypeBadge.astro"

const t = useTranslations(Astro.locals.locale)

const { slug } = Astro.params
const token = Astro.cookies.get("auth_token")?.value
const [job, { data: me }] = await Promise.all([
  slug ? fetchJobOffer(slug, token) : Promise.resolve(null),
  Astro.callAction(actions.auth.getMe, {}),
])
const isOwner = me && job?.owner?.id === me.id

const hasReports = (job?.reports?.length ?? 0) >= REPORT_WARNING_THRESHOLD

const reportResult = Astro.getActionResult(actions.reports.submit)
if (reportResult) {
  return Astro.redirect(
    `${Astro.url.pathname}?reported=${reportResult.error ? "error" : "success"}`
  )
}

const reported = Astro.url.searchParams.get("reported")

const statusLabel: Record<string, string> = {
  submitted: t.auth.statusSubmitted,
  expired: t.auth.statusExpired,
  rejected: t.auth.statusRejected,
  archived: t.auth.statusArchived,
}

const deleteResult = Astro.getActionResult(actions.jobs.delete)
if (deleteResult?.data !== undefined && !deleteResult.error) {
  return Astro.redirect("/account/jobs")
}

const archiveResult = Astro.getActionResult(actions.jobs.archive)
if (archiveResult?.data !== undefined && !archiveResult.error) {
  return Astro.redirect(Astro.url.pathname)
}

const description = job
  ? `${job.company}${job.description ? ` – ${job.description.slice(0, 120)}` : ""}`
  : undefined
const ogImage =
  job?.online_status === "published" ? `${Astro.url.origin}/og/job/${job.slug}.png` : undefined
---

<PageLayout description={description} ogImage={ogImage} title={job?.title ?? t.jobs.pageTitle}>
  {
    !job ? (
      <div class="text-center py-20">
        <h1 class="text-3xl font-bold mb-4">{t.jobs.notFound.headline}</h1>
        <p class="text-base-content/70">{t.jobs.notFound.description}</p>
        <div class="mt-6">
          <a class="btn btn-primary" href="/jobs">
            {t.jobs.backToJobs}
          </a>
        </div>
      </div>
    ) : (
      <>
        <div class="mb-6 flex items-center justify-between gap-4">
          <a class="btn btn-ghost btn-sm gap-1 pl-0" href="/jobs">
            <IconArrowLeft class="h-4 w-4" />
            {t.jobs.backToJobs}
          </a>
          {isOwner && (
            <div class="flex items-center gap-2">
              <a class="btn btn-ghost btn-sm" href="/account/jobs">
                {t.auth.myJobOffers}
              </a>
              <a class="btn btn-outline btn-sm" href={`/job/${job.slug}/edit`}>
                {t.jobs.editJob}
              </a>
              {job.online_status === "published" || job.online_status === "submitted" ? (
                <form
                  action={actions.jobs.archive}
                  method="POST"
                  onsubmit={`return confirm('${t.jobs.archiveConfirm}')`}
                >
                  <input name="documentId" type="hidden" value={job.documentId} />
                  <button class="btn btn-outline btn-sm" type="submit">
                    {t.jobs.archiveJob}
                  </button>
                </form>
              ) : null}
              <form
                action={actions.jobs.delete}
                method="POST"
                onsubmit={`return confirm('${t.jobs.deleteConfirm}')`}
              >
                <input name="documentId" type="hidden" value={job.documentId} />
                <button class="btn btn-outline btn-error btn-sm" type="submit">
                  {t.jobs.deleteJob}
                </button>
              </form>
            </div>
          )}
        </div>

        {job.online_status !== "published" && (
          <div
            class:list={[
              `alert`,
              `${JOB_STATUS_ALERT_CLASS[job.online_status] ?? "alert-neutral"}`,
              `mb-6`,
            ]}
            role="alert"
          >
            <span>
              {statusLabel[job.online_status] ?? job.online_status} – {t.jobs.notPublishedHint}
            </span>
          </div>
        )}

        {hasReports && (
          <div class="alert alert-warning alert-outline mb-6" role="alert">
            <span>{t.reports.warningHint}</span>
          </div>
        )}

        {reported === "success" && (
          <div class="alert alert-success mb-6" role="alert">
            <span>{t.reports.successMessage}</span>
          </div>
        )}

        {reported === "error" && (
          <div class="alert alert-error mb-6" role="alert">
            <span>{t.reports.errorMessage}</span>
          </div>
        )}

        <div class="grid gap-8 lg:grid-cols-3">
          <div class="lg:col-span-2">
            <div class="mb-2 flex items-center gap-2 text-base-content/70">
              <IconStore class="h-4 w-4" />
              <span class="text-sm font-medium">{job.company}</span>
            </div>
            <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">{job.title}</h1>

            <div class="mb-4 flex flex-wrap gap-2">
              <JobTypeBadge jobType={job.job_type} />
              <span class="badge badge-ghost">{t.jobs.jobFields[job.field]}</span>
            </div>

            <div class="mb-6 flex flex-wrap gap-4 text-sm text-base-content/70">
              <div class="flex items-center gap-1.5">
                <IconMapPin class="h-4 w-4 shrink-0" />
                {job.location}
              </div>
              <div class="flex items-center gap-1.5">
                <IconClock class="h-4 w-4 shrink-0" />
                {t.jobs.workingHours(job.working_hours)}
              </div>
            </div>

            <div class="prose prose-sm max-w-none text-base-content/70">
              <p class="whitespace-pre-wrap">{job.description}</p>
            </div>
          </div>

          <aside class="flex flex-col gap-4">
            <div class="rounded-xl border border-base-300 bg-base-100 p-5">
              <h2 class="mb-4 font-semibold">{t.jobs.contactTitle}</h2>
              <dl class="flex flex-col gap-3 text-sm">
                {job.contact?.name && (
                  <div>
                    <dt class="text-base-content/70">Name</dt>
                    <dd class="font-medium">{job.contact.name}</dd>
                  </div>
                )}
                {job.contact?.mail && (
                  <div>
                    <dt class="text-base-content/70">E-Mail</dt>
                    <dd>
                      <a class="link link-primary break-all" href={`mailto:${job.contact.mail}`}>
                        {job.contact.mail}
                      </a>
                    </dd>
                  </div>
                )}
                {job.contact?.phone && (
                  <div>
                    <dt class="text-base-content/70">Tel.</dt>
                    <dd>
                      <a class="link link-primary" href={`tel:${job.contact.phone}`}>
                        {job.contact.phone}
                      </a>
                    </dd>
                  </div>
                )}
              </dl>
            </div>

            {job.external_url && (
              <a
                class="btn btn-primary w-full"
                href={job.external_url}
                rel="noopener noreferrer"
                target="_blank"
              >
                {t.jobs.applyExternal}
                <IconExternalLink class="h-4 w-4" />
              </a>
            )}

            {!isOwner && !reported && (
              <div class="flex justify-end">
                <ReportModal targetId={job.documentId} targetType="job" />
              </div>
            )}
          </aside>
        </div>
      </>
    )
  }
</PageLayout>
