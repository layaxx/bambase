---
import { actions, isInputError } from "astro:actions"
import Layout from "../../layouts/Layout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import { useTranslations } from "../../i18n/translations"

const t = useTranslations(Astro.locals.locale)

const token = Astro.cookies.get("auth_token")?.value
if (!token) {
  return Astro.redirect(`/login?redirect=/job/new`)
}

const result = Astro.getActionResult(actions.jobs.create)

if (result?.data) {
  return Astro.redirect(`/job/${result.data.uuid}`)
}

const inputErrors = isInputError(result?.error) ? result.error.fields : {}
const generalError = result?.error && !isInputError(result.error) ? result.error.message : null
---

<Layout>
  <Header />

  <main class="page-main">
    <div class="mb-6">
      <a href="/jobs" class="btn btn-ghost btn-sm gap-1 pl-0">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        {t.jobs.backToJobs}
      </a>
    </div>

    <section class="mb-8">
      <h1 class="mb-1 text-3xl font-bold tracking-tight sm:text-4xl">{t.jobs.createTitle}</h1>
      <p class="text-base-content/60">{t.jobs.createSubtitle}</p>
    </section>

    {
      generalError && (
        <div role="alert" class="alert alert-error mb-6">
          <span>{generalError}</span>
        </div>
      )
    }

    <form method="POST" action={actions.jobs.create} class="max-w-2xl flex flex-col gap-6">
      <div class="flex flex-col gap-4">
        <div class="form-control">
          <label class="label" for="title">
            <span class="label-text font-medium">{t.jobs.fieldTitle}</span>
          </label>
          <input
            id="title"
            name="title"
            type="text"
            required
            class:list={["input input-bordered w-full", inputErrors.title && "input-error"]}
          />
          {inputErrors.title && <p class="mt-1 text-sm text-error">{inputErrors.title[0]}</p>}
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="form-control">
            <label class="label" for="company">
              <span class="label-text font-medium">{t.jobs.fieldCompany}</span>
            </label>
            <input
              id="company"
              name="company"
              type="text"
              required
              class:list={["input input-bordered w-full", inputErrors.company && "input-error"]}
            />
            {inputErrors.company && <p class="mt-1 text-sm text-error">{inputErrors.company[0]}</p>}
          </div>

          <div class="form-control">
            <label class="label" for="location">
              <span class="label-text font-medium">{t.jobs.fieldLocation}</span>
            </label>
            <input
              id="location"
              name="location"
              type="text"
              required
              class:list={["input input-bordered w-full", inputErrors.location && "input-error"]}
            />
            {
              inputErrors.location && (
                <p class="mt-1 text-sm text-error">{inputErrors.location[0]}</p>
              )
            }
          </div>
        </div>

        <div class="form-control">
          <label class="label" for="working_hours">
            <span class="label-text font-medium">{t.jobs.fieldWorkingHours}</span>
          </label>
          <input
            id="working_hours"
            name="working_hours"
            type="number"
            min="0"
            max="168"
            required
            class:list={[
              "input input-bordered w-full sm:w-40",
              inputErrors.working_hours && "input-error",
            ]}
          />
          {
            inputErrors.working_hours && (
              <p class="mt-1 text-sm text-error">{inputErrors.working_hours[0]}</p>
            )
          }
        </div>

        <div class="form-control">
          <label class="label" for="description">
            <span class="label-text font-medium">{t.jobs.fieldDescription}</span>
          </label>
          <textarea
            id="description"
            name="description"
            rows="6"
            required
            class:list={[
              "textarea textarea-bordered w-full resize-y",
              inputErrors.description && "textarea-error",
            ]}></textarea>
          {
            inputErrors.description && (
              <p class="mt-1 text-sm text-error">{inputErrors.description[0]}</p>
            )
          }
        </div>

        <div class="form-control">
          <label class="label" for="external_url">
            <span class="label-text font-medium">
              {t.jobs.fieldExternalUrl}
              <span class="text-base-content/50 font-normal"> {t.jobs.optionalLabel}</span>
            </span>
          </label>
          <input
            id="external_url"
            name="external_url"
            type="url"
            class:list={["input input-bordered w-full", inputErrors.external_url && "input-error"]}
          />
          {
            inputErrors.external_url && (
              <p class="mt-1 text-sm text-error">{inputErrors.external_url[0]}</p>
            )
          }
        </div>
      </div>

      <div>
        <h2 class="mb-4 font-semibold text-lg">{t.jobs.contactSection}</h2>
        <div class="flex flex-col gap-4">
          <div class="form-control">
            <label class="label" for="contact_name">
              <span class="label-text font-medium">
                {t.jobs.fieldContactName}
                <span class="text-base-content/50 font-normal"> {t.jobs.optionalLabel}</span>
              </span>
            </label>
            <input
              id="contact_name"
              name="contact_name"
              type="text"
              class="input input-bordered w-full"
            />
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="form-control">
              <label class="label" for="contact_mail">
                <span class="label-text font-medium">
                  {t.jobs.fieldContactMail}
                  <span class="text-base-content/50 font-normal"> {t.jobs.optionalLabel}</span>
                </span>
              </label>
              <input
                id="contact_mail"
                name="contact_mail"
                type="email"
                class="input input-bordered w-full"
              />
            </div>

            <div class="form-control">
              <label class="label" for="contact_phone">
                <span class="label-text font-medium">
                  {t.jobs.fieldContactPhone}
                  <span class="text-base-content/50 font-normal"> {t.jobs.optionalLabel}</span>
                </span>
              </label>
              <input
                id="contact_phone"
                name="contact_phone"
                type="tel"
                class="input input-bordered w-full"
              />
            </div>
          </div>
        </div>
      </div>

      <div>
        <button type="submit" class="btn btn-primary">
          {t.jobs.submitJob}
        </button>
      </div>
    </form>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
</style>
