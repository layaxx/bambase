---
import { actions, isInputError } from "astro:actions"
import PageLayout from "@/layouts/PageLayout.astro"
import { useTranslations } from "@/i18n/translations"
import IconArrowLeft from "@/components/icons/IconArrowLeft.astro"
import JobForm from "@/components/jobs/JobForm.astro"

const t = useTranslations(Astro.locals.locale)

const token = Astro.cookies.get("auth_token")?.value
if (!token) {
  return Astro.redirect(`/login?redirect=/job/new`)
}

const result = Astro.getActionResult(actions.jobs.create)

if (result?.data) {
  return Astro.redirect(`/job/${result.data.slug}`)
}

const inputErrors = isInputError(result?.error) ? result.error.fields : {}
const generalError = result?.error && !isInputError(result.error) ? result.error.message : null
---

<PageLayout title={t.jobs.createTitle}>
  <div class="mb-6">
    <a class="btn btn-ghost btn-sm gap-1 pl-0" href="/jobs">
      <IconArrowLeft class="h-4 w-4" />
      {t.jobs.backToJobs}
    </a>
  </div>

  <section class="mb-8">
    <h1 class="mb-1 text-3xl font-bold tracking-tight sm:text-4xl">{t.jobs.createTitle}</h1>
    <p class="text-base-content/70">{t.jobs.createSubtitle}</p>
  </section>

  {
    generalError && (
      <div class="alert alert-error mb-6" role="alert">
        <span>{generalError}</span>
      </div>
    )
  }

  <JobForm
    action={actions.jobs.create}
    cancelHref="/jobs"
    enableDraft={true}
    inputErrors={inputErrors}
    submitLabel={t.jobs.submitJob}
  />
</PageLayout>
