---
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import Layout from "../../layouts/Layout.astro"
import { fetchJobOffer } from "../../utils/api"
import { useTranslations } from "../../i18n/translations"

const t = useTranslations(Astro.locals.locale)

const { uuid } = Astro.params
const token = Astro.cookies.get("auth_token")?.value
const job = uuid ? await fetchJobOffer(uuid, token) : null
---

<Layout>
  <Header />

  <main class="page-main">
    {
      !job ? (
        <div class="text-center py-20">
          <h1 class="text-3xl font-bold mb-4">Kein Job gefunden</h1>
          <p class="text-base-content/60">nicht gefunden</p>
          <div class="mt-6">
            <a href="/jobs" class="btn btn-primary">
              {t.jobs.backToJobs}
            </a>
          </div>
        </div>
      ) : (
        <>
          <div class="mb-6">
            <a href="/jobs" class="btn btn-ghost btn-sm gap-1 pl-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
                aria-hidden="true">
                <path d="m12 19-7-7 7-7" />
                <path d="M19 12H5" />
              </svg>
              {t.jobs.backToJobs}
            </a>
          </div>

          <div class="grid gap-8 lg:grid-cols-3">
            <div class="lg:col-span-2">
              <div class="mb-2 flex items-center gap-2 text-base-content/60">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true">
                  <path d="M10 12h4" />
                  <path d="M10 8h4" />
                  <path d="M14 21v-3a2 2 0 0 0-4 0v3" />
                  <path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2" />
                  <path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16" />
                </svg>
                <span class="text-sm font-medium">{job.company}</span>
              </div>
              <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">{job.title}</h1>

              <div class="mb-6 flex flex-wrap gap-4 text-sm text-base-content/60">
                <div class="flex items-center gap-1.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4 shrink-0"
                    aria-hidden="true">
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  {job.location}
                </div>
                <div class="flex items-center gap-1.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4 shrink-0"
                    aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {t.jobs.workingHours(job.working_hours)}
                </div>
              </div>

              <div class="prose prose-sm max-w-none text-base-content/80">
                <p class="whitespace-pre-wrap">{job.description}</p>
              </div>
            </div>

            <aside class="flex flex-col gap-4">
              <div class="rounded-xl border border-base-300 bg-base-100 p-5">
                <h2 class="mb-4 font-semibold">{t.jobs.contactTitle}</h2>
                <dl class="flex flex-col gap-3 text-sm">
                  {job.contact?.name && (
                    <div>
                      <dt class="text-base-content/60">Name</dt>
                      <dd class="font-medium">{job.contact.name}</dd>
                    </div>
                  )}
                  {job.contact?.mail && (
                    <div>
                      <dt class="text-base-content/60">E-Mail</dt>
                      <dd>
                        <a href={`mailto:${job.contact.mail}`} class="link link-primary break-all">
                          {job.contact.mail}
                        </a>
                      </dd>
                    </div>
                  )}
                  {job.contact?.phone && (
                    <div>
                      <dt class="text-base-content/60">Tel.</dt>
                      <dd>
                        <a href={`tel:${job.contact.phone}`} class="link link-primary">
                          {job.contact.phone}
                        </a>
                      </dd>
                    </div>
                  )}
                </dl>
              </div>

              {job.external_url && (
                <a
                  href={job.external_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary w-full">
                  {t.jobs.applyExternal}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                    aria-hidden="true">
                    <path d="M15 3h6v6" />
                    <path d="M10 14 21 3" />
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  </svg>
                </a>
              )}
            </aside>
          </div>
        </>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
</style>
