---
import PageLayout from "@/layouts/PageLayout.astro"
import { useTranslations } from "@/i18n/translations"
import ImpressumGerman from "@/components/static/impressum.de.astro"
import ImpressumEnglish from "@/components/static/impressum.en.astro"

const t = useTranslations(Astro.locals.locale)
---

<PageLayout title={t.impressum.pageTitle}>
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl mb-2">{t.impressum.pageTitle}</h1>

  {Astro.locals.locale === "de" ? <ImpressumGerman /> : <ImpressumEnglish />}
</PageLayout>
