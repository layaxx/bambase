---
import PageLayout from "@/layouts/PageLayout.astro"
import { useTranslations } from "@/i18n/translations"

const t = useTranslations(Astro.locals.locale)
---

<PageLayout title={t.page500.pageTitle}>
  <div class="flex flex-col items-center justify-center py-24 text-center gap-4">
    <p class="text-8xl font-bold text-base-content/40">{t.page500.headline}</p>
    <p class="text-base-content/70 max-w-sm">{t.page500.description}</p>
    <a class="btn btn-neutral mt-2" href="/">{t.page500.backHome}</a>
  </div>
</PageLayout>
