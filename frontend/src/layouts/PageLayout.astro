---
import AppLayout from "@/layouts/AppLayout.astro"

interface Props {
  title?: string
  description?: string
  ogImage?: string
}
const { title, description, ogImage } = Astro.props
---

<AppLayout description={description} ogImage={ogImage} title={title}>
  <main class="max-w-7xl mx-auto px-4 py-8 block grow w-full" id="main-content">
    <slot />
  </main>
</AppLayout>
